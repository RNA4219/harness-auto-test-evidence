{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/notification-operating-record.schema.json",
  "title": "HATE Notification Operating Record",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "operating_record_id",
    "severity",
    "owner",
    "team",
    "due_at",
    "sla_breached",
    "payload_hash",
    "redaction_report_ref",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "notification-operating-record"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "operating_record_id": {"type": "string"},
    "severity": {"type": "string"},
    "owner": {"type": "string"},
    "team": {"type": "string"},
    "due_at": {"type": "string"},
    "sla_breached": {"type": "boolean"},
    "payload_hash": {"type": "string"},
    "redaction_report_ref": {"type": "string"},
    "sourceRef": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
