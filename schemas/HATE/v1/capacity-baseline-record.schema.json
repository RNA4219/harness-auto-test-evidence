{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/capacity-baseline-record.schema.json",
  "title": "HATE Capacity Baseline Record",
  "type": "object",
  "required": ["record_type", "record_id", "created_at", "decision_basis", "readiness_effect", "unsafe_output_policy", "baseline_id", "machine_profile", "scenario_ids", "dataset_hashes", "run_count", "sourceRefs"],
  "properties": {
    "record_type": {"const": "capacity-baseline-record"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "baseline_id": {"type": "string"},
    "machine_profile": {"type": "object"},
    "scenario_ids": {"type": "array", "items": {"type": "string"}},
    "dataset_hashes": {"type": "array", "items": {"type": "string"}},
    "run_count": {"type": "integer", "minimum": 0},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [{"required": ["actor"]}, {"required": ["system_actor"]}],
  "additionalProperties": true
}
