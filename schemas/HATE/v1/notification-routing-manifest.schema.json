{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/notification-routing-manifest.schema.json",
  "title": "HATE Notification Routing Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "plan_id",
    "operating_record_id",
    "routing_entries",
    "sourceRefs",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy"
  ],
  "properties": {
    "schema_version": {
      "const": "HATE/v1"
    },
    "record_type": {
      "const": "notification-routing-manifest"
    },
    "plan_id": {
      "type": "string"
    },
    "operating_record_id": {
      "type": "string"
    },
    "routing_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "record_type",
          "operating_record_id",
          "subscriber_id",
          "routing_role",
          "delivery_target",
          "target_ref",
          "dedupe_key",
          "payload_hash",
          "redaction_report_ref",
          "sourceRefs"
        ],
        "properties": {
          "record_type": {
            "const": "notification-routing-entry"
          },
          "operating_record_id": {
            "type": "string"
          },
          "subscriber_id": {
            "type": "string"
          },
          "routing_role": {
            "type": "string",
            "enum": [
              "primary",
              "escalation"
            ]
          },
          "delivery_target": {
            "type": "string",
            "enum": [
              "slack_channel",
              "slack_dm",
              "email",
              "github_comment",
              "github_check_annotation",
              "webhook"
            ]
          },
          "target_ref": {
            "type": "string"
          },
          "dedupe_key": {
            "type": "string"
          },
          "payload_hash": {
            "type": "string"
          },
          "redaction_report_ref": {
            "type": "string"
          },
          "sourceRefs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "system_actor": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_basis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "readiness_effect": {
      "type": "string",
      "enum": [
        "none",
        "hold"
      ]
    },
    "unsafe_output_policy": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true,
  "anyOf": [
    {
      "required": [
        "actor"
      ]
    },
    {
      "required": [
        "system_actor"
      ]
    }
  ]
}
