{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/adapter-registry.schema.json",
  "title": "HATE Adapter Registry",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "registry_version",
    "adapters",
    "summary",
    "source_refs",
    "release_gate_override",
    "publish_gate_override"
  ],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {"const": "adapter_registry"},
    "registry_version": {"type": "string"},
    "adapters": {"type": "array"},
    "summary": {"type": "object", "required": ["adapter_count", "by_type", "all_have_required_manifest_fields"]},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "release_gate_override": {"const": false},
    "publish_gate_override": {"const": false}
  },
  "additionalProperties": true
}
