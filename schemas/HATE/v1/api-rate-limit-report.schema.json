{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/HATE/v1/api-rate-limit-report.schema.json",
  "title": "HATE API Rate Limit Report",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "source_version",
    "status",
    "readiness_effect",
    "request_id",
    "tenant",
    "actor_id",
    "route",
    "method",
    "quota",
    "response_headers",
    "audit_events",
    "findings",
    "sourceRefs"
  ],
  "properties": {
    "schema_version": { "const": "HATE/v1" },
    "record_type": { "const": "api-rate-limit-report" },
    "source_version": { "type": "string" },
    "status": { "enum": ["pass", "hold"] },
    "readiness_effect": { "enum": ["none", "hold"] },
    "finding_code": { "type": "string" },
    "request_id": { "type": "string", "minLength": 1 },
    "tenant": {
      "type": "object",
      "required": ["organization_id", "workspace_id"],
      "properties": {
        "organization_id": { "type": "string" },
        "workspace_id": { "type": "string" }
      },
      "additionalProperties": false
    },
    "actor_id": { "type": "string" },
    "route": { "type": "string" },
    "method": { "type": "string" },
    "quota": {
      "type": "object",
      "required": ["limit", "window_seconds", "used", "remaining", "reset_after_seconds"],
      "properties": {
        "limit": { "type": "integer", "minimum": 1 },
        "window_seconds": { "type": "integer", "minimum": 1 },
        "used": { "type": "integer", "minimum": 0 },
        "remaining": { "type": "integer", "minimum": 0 },
        "reset_after_seconds": { "type": "integer", "minimum": 1 },
        "retry_after_seconds": { "type": ["integer", "null"], "minimum": 1 }
      },
      "additionalProperties": false
    },
    "response_headers": {
      "type": "object",
      "required": ["X-RateLimit-Limit", "X-RateLimit-Remaining", "X-RateLimit-Reset-After"],
      "additionalProperties": { "type": "string" }
    },
    "audit_events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["event_type", "request_id", "tenant", "actor_id", "route", "method", "decision", "usage", "created_at"],
        "properties": {
          "event_type": { "const": "api_rate_limit_decision" },
          "request_id": { "type": "string" },
          "tenant": { "type": "object" },
          "actor_id": { "type": "string" },
          "route": { "type": "string" },
          "method": { "type": "string" },
          "decision": { "enum": ["allow", "deny"] },
          "finding_code": { "type": "string" },
          "usage": { "type": "object" },
          "created_at": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message", "source_refs"],
        "properties": {
          "code": { "type": "string" },
          "severity": { "enum": ["low", "medium", "high", "critical"] },
          "message": { "type": "string" },
          "source_refs": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "sourceRefs": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
