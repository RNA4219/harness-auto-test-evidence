{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/history-analytics-result.schema.json",
  "title": "HATE History Analytics Result",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "metrics",
    "sample_count",
    "excluded_count",
    "exclusion_reasons",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "history-analytics-result"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "metrics": {"type": "object", "additionalProperties": true},
    "sample_count": {"type": "integer"},
    "excluded_count": {"type": "integer"},
    "exclusion_reasons": {"type": "array", "items": {"type": "string"}},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
