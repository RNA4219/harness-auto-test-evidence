{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/test-quality-report.schema.json",
  "title": "HATE Test Quality Report",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "report_id",
    "overall_status",
    "readiness_effect",
    "quality_config",
    "findings",
    "summary",
    "analysis_scope",
    "input_refs",
    "confidence",
    "limits",
    "sourceRefs"
  ],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {"const": "test-quality-report"},
    "report_id": {"type": "string"},
    "overall_status": {"type": "string", "enum": ["pass", "hold", "blocked"]},
    "readiness_effect": {"type": "string", "enum": ["none", "hold", "blocked"]},
    "quality_config": {
      "type": "object",
      "required": ["test_patterns", "anti_patterns", "quality_metrics"],
      "properties": {
        "test_patterns": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["pattern_id", "pattern_type", "quality_dimension", "confidence", "sourceRef", "rationale", "verified"],
            "properties": {
              "pattern_id": {"type": "string"},
              "pattern_type": {"type": "string"},
              "quality_dimension": {"type": "string"},
              "confidence": {"type": "number", "minimum": 0, "maximum": 1},
              "sourceRef": {"type": "string"},
              "rationale": {"type": "string"},
              "verified": {"type": "boolean"}
            },
            "additionalProperties": true
          }
        },
        "anti_patterns": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["anti_pattern_id", "anti_pattern_type", "severity", "confidence", "sourceRef", "rationale", "mitigated"],
            "properties": {
              "anti_pattern_id": {"type": "string"},
              "anti_pattern_type": {"type": "string"},
              "severity": {"type": "string"},
              "confidence": {"type": "number", "minimum": 0, "maximum": 1},
              "sourceRef": {"type": "string"},
              "rationale": {"type": "string"},
              "mitigated": {"type": "boolean"}
            },
            "additionalProperties": true
          }
        },
        "quality_metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["metric_id", "metric_type", "value", "confidence", "sourceRef", "rationale"],
            "properties": {
              "metric_id": {"type": "string"},
              "metric_type": {"type": "string"},
              "value": {"type": "number"},
              "confidence": {"type": "number", "minimum": 0, "maximum": 1},
              "sourceRef": {"type": "string"},
              "rationale": {"type": "string"}
            },
            "additionalProperties": true
          }
        },
        "test_sources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["test_id", "sourceRef", "text", "fixture_size_bytes", "snapshot_line_count"],
            "properties": {
              "test_id": {"type": "string"},
              "sourceRef": {"type": "string"},
              "text": {"type": "string"},
              "fixture_size_bytes": {"type": "integer", "minimum": 0},
              "snapshot_line_count": {"type": "integer", "minimum": 0}
            },
            "additionalProperties": true
          }
        },
        "analysis_scope": {"type": "string"},
        "input_refs": {"type": "array", "items": {"type": "string"}},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "limits": {
          "type": "object",
          "required": ["max_test_patterns", "max_anti_patterns", "max_quality_metrics", "confidence_threshold"],
          "properties": {
            "max_test_patterns": {"type": "integer", "minimum": 0},
            "max_anti_patterns": {"type": "integer", "minimum": 0},
            "max_quality_metrics": {"type": "integer", "minimum": 0},
            "confidence_threshold": {"type": "number", "minimum": 0, "maximum": 1},
            "max_fixture_size_bytes": {"type": "integer", "minimum": 0},
            "max_snapshot_line_count": {"type": "integer", "minimum": 0}
          },
          "additionalProperties": true
        },
        "determinism_available": {"type": "boolean"},
        "timeout_available": {"type": "boolean"},
        "isolation_available": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message", "sourceRef", "readiness_effect"],
        "properties": {
          "code": {"type": "string"},
          "severity": {"type": "string"},
          "message": {"type": "string"},
          "sourceRef": {"type": "string"},
          "readiness_effect": {"type": "string", "enum": ["hold", "blocked"]}
        },
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "object",
      "required": ["test_pattern_count", "anti_pattern_count", "quality_metric_count", "confidence", "finding_count"],
      "properties": {
        "test_pattern_count": {"type": "integer", "minimum": 0},
        "anti_pattern_count": {"type": "integer", "minimum": 0},
        "quality_metric_count": {"type": "integer", "minimum": 0},
        "test_source_count": {"type": "integer", "minimum": 0},
        "duplicate_test_count": {"type": "integer", "minimum": 0},
        "source_anti_pattern_count": {"type": "integer", "minimum": 0},
        "unverified_pattern_count": {"type": "integer", "minimum": 0},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "finding_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": true
    },
    "test_quality_diagnostics": {
      "type": "object",
      "required": [
        "duplicate_test_ids",
        "source_anti_patterns",
        "large_fixture_test_ids",
        "overbroad_snapshot_test_ids",
        "unverified_pattern_ids"
      ],
      "properties": {
        "duplicate_test_ids": {"type": "array", "items": {"type": "string"}},
        "source_anti_patterns": {
          "type": "object",
          "additionalProperties": {"type": "array", "items": {"type": "string"}}
        },
        "large_fixture_test_ids": {"type": "array", "items": {"type": "string"}},
        "overbroad_snapshot_test_ids": {"type": "array", "items": {"type": "string"}},
        "unverified_pattern_ids": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "analysis_scope": {"type": "string"},
    "input_refs": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "limits": {
      "type": "object",
      "required": ["max_test_patterns", "max_anti_patterns", "max_quality_metrics", "confidence_threshold"],
      "properties": {
        "max_test_patterns": {"type": "integer", "minimum": 0},
        "max_anti_patterns": {"type": "integer", "minimum": 0},
        "max_quality_metrics": {"type": "integer", "minimum": 0},
        "confidence_threshold": {"type": "number", "minimum": 0, "maximum": 1},
        "max_fixture_size_bytes": {"type": "integer", "minimum": 0},
        "max_snapshot_line_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": true
    },
    "sourceRefs": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
