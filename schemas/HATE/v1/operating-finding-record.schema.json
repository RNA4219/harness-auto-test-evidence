{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/operating-finding-record.schema.json",
  "title": "HATE Operating Finding Record",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "operating_record_id",
    "entity_kind",
    "entity_id",
    "status",
    "severity",
    "readiness_effect",
    "owner",
    "due_date",
    "expiry_date",
    "sourceRefs",
    "evidence_refs",
    "decision_basis",
    "last_event_id"
  ],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {"const": "operating-finding-record"},
    "operating_record_id": {"type": "string"},
    "entity_kind": {"type": "string", "enum": ["finding", "risk_debt", "manual_review", "policy_drift", "external_hold"]},
    "entity_id": {"type": "string"},
    "status": {"type": "string", "enum": ["open", "accepted", "expired", "resolved", "revoked", "superseded", "merged"]},
    "severity": {"type": "string"},
    "readiness_effect": {"type": "string"},
    "owner": {"type": "string"},
    "due_date": {"type": "string"},
    "expiry_date": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "decision_basis": {"type": "array"},
    "last_event_id": {"type": "string"},
    "superseding_record_id": {"type": "string"},
    "merged_into_record_id": {"type": "string"},
    "tracker_syncs": {"type": "array"},
    "notifications": {"type": "array"},
    "retention_events": {"type": "array"},
    "legal_holds": {"type": "array"},
    "rebuild_events": {"type": "array"},
    "manual_review": {"type": "object"}
  },
  "additionalProperties": true
}
