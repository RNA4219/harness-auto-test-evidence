{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/real-repo-quarantine-event.schema.json",
  "title": "HATE Real Repo Quarantine Event",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "repo_id",
    "quarantine_reason",
    "retry_isolation_group",
    "external_repair_allowed",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "real-repo-quarantine-event"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "repo_id": {"type": "string"},
    "quarantine_reason": {"type": "string"},
    "retry_isolation_group": {"type": "string"},
    "external_repair_allowed": {"type": "boolean"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
