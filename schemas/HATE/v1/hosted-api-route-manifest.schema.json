{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/hosted-api-route-manifest.schema.json",
  "title": "HATE Hosted API Route Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "manifest_id",
    "base_path",
    "routes",
    "summary",
    "sourceRefs",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy"
  ],
  "properties": {
    "schema_version": {
      "const": "HATE/v1"
    },
    "record_type": {
      "const": "hosted-api-route-manifest"
    },
    "manifest_id": {
      "type": "string"
    },
    "base_path": {
      "type": "string"
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "record_type",
          "operation_id",
          "method",
          "path",
          "resource",
          "action",
          "required_scope",
          "tenant_scoped",
          "audit_required",
          "rate_limited",
          "description"
        ],
        "properties": {
          "record_type": {
            "const": "hosted-api-route-contract"
          },
          "operation_id": {
            "type": "string"
          },
          "method": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "resource": {
            "type": "string"
          },
          "action": {
            "type": "string",
            "enum": [
              "read",
              "write"
            ]
          },
          "required_scope": {
            "type": "string"
          },
          "tenant_scoped": {
            "type": "boolean"
          },
          "audit_required": {
            "type": "boolean"
          },
          "rate_limited": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "route_count",
        "tenant_scoped_count",
        "audit_required_count",
        "rate_limited_count",
        "write_route_count"
      ],
      "properties": {
        "route_count": {
          "type": "integer",
          "minimum": 0
        },
        "tenant_scoped_count": {
          "type": "integer",
          "minimum": 0
        },
        "audit_required_count": {
          "type": "integer",
          "minimum": 0
        },
        "rate_limited_count": {
          "type": "integer",
          "minimum": 0
        },
        "write_route_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "system_actor": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_basis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "readiness_effect": {
      "type": "string",
      "enum": [
        "none",
        "hold"
      ]
    },
    "unsafe_output_policy": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true,
  "anyOf": [
    {
      "required": [
        "actor"
      ]
    },
    {
      "required": [
        "system_actor"
      ]
    }
  ]
}
