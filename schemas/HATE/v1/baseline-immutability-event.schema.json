{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/baseline-immutability-event.schema.json",
  "title": "HATE Baseline Immutability Event",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "baseline_id",
    "event_type",
    "before_state",
    "after_state",
    "before_hash",
    "after_hash",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "baseline-immutability-event"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "baseline_id": {"type": "string"},
    "event_type": {"type": "string"},
    "before_state": {"type": "string"},
    "after_state": {"type": "string"},
    "before_hash": {"type": "string"},
    "after_hash": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
