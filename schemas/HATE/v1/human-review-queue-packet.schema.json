{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/human-review-queue-packet.schema.json",
  "title": "HATE Human Review Queue Packet",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "packet_id",
    "queue_item",
    "allowed_actions",
    "evidence_refs",
    "findings",
    "summary",
    "sourceRefs",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy"
  ],
  "properties": {
    "schema_version": {
      "const": "HATE/v1"
    },
    "record_type": {
      "const": "human-review-queue-packet"
    },
    "packet_id": {
      "type": "string"
    },
    "queue_item": {
      "type": "object",
      "required": [
        "record_type",
        "review_id",
        "operating_record_id",
        "required_decision",
        "reviewer",
        "owner",
        "due_date",
        "expiry_date",
        "status",
        "decision",
        "decision_hash",
        "workflow_report_status"
      ],
      "properties": {
        "record_type": {
          "const": "human-review-queue-item"
        },
        "review_id": {
          "type": "string"
        },
        "operating_record_id": {
          "type": "string"
        },
        "required_decision": {
          "type": "string"
        },
        "reviewer": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "due_date": {
          "type": "string"
        },
        "expiry_date": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "decision": {
          "type": "string"
        },
        "decision_hash": {
          "type": "string"
        },
        "workflow_report_status": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "allowed_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "assign_reviewer",
          "attach_evidence",
          "approve",
          "deny",
          "expire",
          "resolve",
          "revoke",
          "supersede",
          "replay"
        ]
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "severity",
          "message",
          "sourceRef",
          "readiness_effect"
        ],
        "properties": {
          "code": {
            "type": "string",
            "enum": [
              "human_review_queue_identity_missing",
              "human_review_reviewer_missing",
              "human_review_queue_sla_missing",
              "human_review_queue_blocked_by_workflow_findings"
            ]
          },
          "severity": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "sourceRef": {
            "type": "string"
          },
          "readiness_effect": {
            "type": "string",
            "enum": [
              "hold"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "ready_for_queue",
        "allowed_action_count",
        "evidence_ref_count",
        "finding_count",
        "status"
      ],
      "properties": {
        "ready_for_queue": {
          "type": "boolean"
        },
        "allowed_action_count": {
          "type": "integer"
        },
        "evidence_ref_count": {
          "type": "integer"
        },
        "finding_count": {
          "type": "integer"
        },
        "status": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "system_actor": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_basis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "readiness_effect": {
      "type": "string",
      "enum": [
        "none",
        "hold"
      ]
    },
    "unsafe_output_policy": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true,
  "anyOf": [
    {
      "required": [
        "actor"
      ]
    },
    {
      "required": [
        "system_actor"
      ]
    }
  ]
}
