{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HATE security procurement report",
  "type": "object",
  "required": ["schema_version", "record_type", "report_id", "overall_status", "readiness_effect", "procurement_config", "findings", "summary", "sourceRefs"],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {"const": "security-procurement-report"},
    "report_id": {"type": "string"},
    "overall_status": {"enum": ["pass", "hold"]},
    "readiness_effect": {"enum": ["none", "hold"]},
    "procurement_config": {"type": "object"},
    "findings": {"type": "array"},
    "summary": {"type": "object"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}}
  }
}
