{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/plugin-package-manifest.schema.json",
  "title": "HATE Plugin Package Manifest",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "plugin_id",
    "plugin_version",
    "api_version",
    "package_hash",
    "observed_package_hash",
    "signature_algorithm",
    "signature_ref",
    "signature_valid",
    "trust_source",
    "allowlist_ref",
    "revocation_ref",
    "compatibility_status",
    "capabilities",
    "resource_limits",
    "migration_note_ref",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "plugin-package-manifest"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "plugin_id": {"type": "string"},
    "plugin_version": {"type": "string"},
    "api_version": {"type": "string"},
    "package_hash": {"type": "string"},
    "observed_package_hash": {"type": "string"},
    "signature_algorithm": {"type": "string"},
    "signature_ref": {"type": "string"},
    "signature_valid": {"type": "boolean", "description": "External evidence assertion only; HATE v0.2.0 does not cryptographically verify plugin signatures."},
    "trust_source": {"type": "string"},
    "allowlist_ref": {"type": "string"},
    "revocation_ref": {"type": "string"},
    "compatibility_status": {"type": "string"},
    "capabilities": {"type": "array", "items": {"type": "string"}},
    "resource_limits": {"type": "object", "additionalProperties": true},
    "migration_note_ref": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
