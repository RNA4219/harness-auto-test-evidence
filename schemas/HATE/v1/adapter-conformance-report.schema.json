{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/adapter-conformance-report.schema.json",
  "title": "Adapter Conformance Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "manifest_id",
    "parserVersion",
    "result",
    "required_family_count",
    "observed_family_count",
    "family_summaries",
    "entries",
    "findings",
    "status",
    "readiness_effect",
    "sourceRefs"
  ],
  "properties": {
    "schema_version": { "const": "HATE/v1" },
    "record_type": { "const": "adapter-conformance-report" },
    "manifest_id": { "type": "string", "minLength": 1 },
    "parserVersion": { "type": "string", "minLength": 1 },
    "result": { "enum": ["pass", "fail"] },
    "required_family_count": { "type": "integer", "minimum": 0 },
    "observed_family_count": { "type": "integer", "minimum": 0 },
    "family_summaries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "family",
          "adapter_id",
          "dialects",
          "fixture_paths",
          "positive_count",
          "negative_count",
          "malformed_count",
          "partial_count",
          "path_normalization_count",
          "metadata_preservation_count",
          "expected_output_ref",
          "reviewed_at",
          "review_owner",
          "stale_after_days",
          "unsupported_claims",
          "sourceRefs"
        ],
        "properties": {
          "family": { "type": "string", "minLength": 1 },
          "adapter_id": { "type": "string", "minLength": 1 },
          "dialects": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "fixture_paths": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "positive_count": { "type": "integer", "minimum": 0 },
          "negative_count": { "type": "integer", "minimum": 0 },
          "malformed_count": { "type": "integer", "minimum": 0 },
          "partial_count": { "type": "integer", "minimum": 0 },
          "path_normalization_count": { "type": "integer", "minimum": 0 },
          "metadata_preservation_count": { "type": "integer", "minimum": 0 },
          "expected_output_ref": { "type": "string" },
          "reviewed_at": { "type": "string" },
          "review_owner": { "type": "string" },
          "stale_after_days": { "type": "integer", "minimum": 1 },
          "unsupported_claims": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "sourceRefs": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "adapter_id",
          "fixture_id",
          "result",
          "severity",
          "sourceRefs",
          "parserVersion",
          "produced_record_counts"
        ],
        "properties": {
          "adapter_id": { "type": "string", "minLength": 1 },
          "fixture_id": { "type": "string", "minLength": 1 },
          "result": { "enum": ["pass", "fail"] },
          "severity": { "enum": ["pass", "low", "medium", "high", "critical"] },
          "sourceRefs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "parserVersion": { "type": "string", "minLength": 1 },
          "produced_record_counts": {
            "type": "object",
            "additionalProperties": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "severity", "message", "sourceRef", "readiness_effect"],
        "properties": {
          "code": {
            "enum": [
              "adapter_corpus_family_missing",
              "adapter_corpus_dialect_missing",
              "adapter_corpus_fixture_count_below_minimum",
              "adapter_corpus_stale_fixture",
              "adapter_corpus_unsupported_claim",
              "adapter_corpus_expected_output_missing",
              "missing_required",
              "unsupported_manifest_schema",
              "invalid_adapter_id",
              "invalid_input_formats",
              "invalid_emitted_records",
              "unknown_output_record",
              "invalid_schema_range",
              "unsupported_schema_version",
              "invalid_parser_entrypoint",
              "invalid_feature_flags",
              "missing_conformance_fixtures",
              "invalid_fixture",
              "invalid_fixture_records",
              "capability_mismatch",
              "manifest_parse_error",
              "duplicate_adapter_id"
            ]
          },
          "severity": { "enum": ["error", "low", "medium", "high", "critical"] },
          "message": { "type": "string", "minLength": 1 },
          "sourceRef": { "type": "string", "minLength": 1 },
          "readiness_effect": { "enum": ["none", "soft_gap", "hold"] }
        }
      }
    },
    "status": { "enum": ["pass", "hold"] },
    "readiness_effect": { "enum": ["none", "hold"] },
    "sourceRefs": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  }
}
