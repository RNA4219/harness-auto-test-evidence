{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/baseline-promotion-request.schema.json",
  "title": "HATE Baseline Promotion Request",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "baseline_id",
    "repo_id",
    "suite_id",
    "candidate_run_id",
    "actor",
    "reason",
    "evidence_refs",
    "policy_hash",
    "expires_at",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "baseline-promotion-request"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "baseline_id": {"type": "string"},
    "repo_id": {"type": "string"},
    "suite_id": {"type": "string"},
    "candidate_run_id": {"type": "string"},
    "reason": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "policy_hash": {"type": "string"},
    "expires_at": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
