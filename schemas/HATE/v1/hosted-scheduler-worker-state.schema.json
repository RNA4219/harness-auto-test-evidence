{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/hosted-scheduler-worker-state.schema.json",
  "title": "HATE Hosted Scheduler Worker State",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "worker_id",
    "queue_id",
    "lease_id",
    "job_id",
    "job_kind",
    "lease_state",
    "attempt",
    "max_attempts",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "hosted-scheduler-worker-state"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "worker_id": {"type": "string"},
    "queue_id": {"type": "string"},
    "lease_id": {"type": "string"},
    "job_id": {"type": "string"},
    "job_kind": {"type": "string"},
    "lease_state": {"type": "string"},
    "attempt": {"type": "integer"},
    "max_attempts": {"type": "integer"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
