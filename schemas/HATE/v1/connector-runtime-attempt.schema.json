{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/connector-runtime-attempt.schema.json",
  "title": "HATE Connector Runtime Attempt",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "connector_id",
    "connector_type",
    "mode",
    "endpoint_ref",
    "external_ref",
    "sync_status",
    "payload_hash",
    "redaction_report_ref",
    "side_effect_performed",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "connector-runtime-attempt"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "connector_id": {"type": "string"},
    "connector_type": {"type": "string"},
    "mode": {"type": "string"},
    "endpoint_ref": {"type": "string"},
    "external_ref": {"type": "string"},
    "sync_status": {"type": "string"},
    "payload_hash": {"type": "string"},
    "redaction_report_ref": {"type": "string"},
    "side_effect_performed": {"type": "boolean"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
