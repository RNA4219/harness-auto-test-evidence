{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/platform-benchmark-report.schema.json",
  "title": "HATE Platform Benchmark Report",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "report_id",
    "overall_status",
    "readiness_effect",
    "dataset_class",
    "seed",
    "dataset_counts",
    "deterministic_hash",
    "distribution",
    "metrics",
    "budgets",
    "baseline",
    "degradations",
    "findings",
    "summary",
    "sourceRefs"
  ],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {"const": "platform-benchmark-report"},
    "report_id": {"type": "string"},
    "overall_status": {"type": "string", "enum": ["pass", "hold"]},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "dataset_class": {"type": "string"},
    "seed": {"type": "string"},
    "dataset_counts": {"type": "object"},
    "deterministic_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "distribution": {"type": "object"},
    "metrics": {"type": "object"},
    "budgets": {"type": "object"},
    "baseline": {"type": "object"},
    "degradations": {"type": "array", "items": {"type": "string"}},
    "findings": {"type": "array"},
    "summary": {"type": "object"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
