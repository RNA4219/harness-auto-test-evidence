{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/platform-plugin-sandbox-report.schema.json",
  "title": "HATE Platform Plugin Sandbox Report",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "report_id",
    "overall_status",
    "readiness_effect",
    "profile",
    "plugin_id",
    "detector_id",
    "execution_mode",
    "mode_decision",
    "input_decision",
    "resource_decision",
    "output_decision",
    "isolation_decision",
    "findings",
    "summary",
    "sourceRefs"
  ],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {"const": "platform-plugin-sandbox-report"},
    "report_id": {"type": "string"},
    "overall_status": {"type": "string", "enum": ["pass", "hold", "blocked"]},
    "readiness_effect": {"type": "string", "enum": ["none", "hold", "blocked"]},
    "profile": {"type": "string"},
    "plugin_id": {"type": "string"},
    "detector_id": {"type": "string"},
    "execution_mode": {"type": "string"},
    "mode_decision": {"type": "object"},
    "input_decision": {"type": "object"},
    "resource_decision": {"type": "object"},
    "output_decision": {"type": "object"},
    "isolation_decision": {"type": "object"},
    "findings": {"type": "array"},
    "summary": {"type": "object"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
