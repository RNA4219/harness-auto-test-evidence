{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/human-review-queue-item.schema.json",
  "title": "HATE Human Review Queue Item",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "review_id",
    "operating_record_id",
    "required_decision",
    "reviewer",
    "owner",
    "due_date",
    "expiry_date",
    "status",
    "decision",
    "decision_hash",
    "workflow_report_status",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "human-review-queue-item"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "review_id": {"type": "string"},
    "operating_record_id": {"type": "string"},
    "required_decision": {"type": "string"},
    "reviewer": {"type": "string"},
    "owner": {"type": "string"},
    "due_date": {"type": "string"},
    "expiry_date": {"type": "string"},
    "status": {"type": "string"},
    "decision": {"type": "string"},
    "decision_hash": {"type": "string"},
    "workflow_report_status": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
