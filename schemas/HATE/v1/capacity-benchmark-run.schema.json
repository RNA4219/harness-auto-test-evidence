{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/capacity-benchmark-run.schema.json",
  "title": "HATE Capacity Benchmark Run",
  "type": "object",
  "required": ["record_type", "record_id", "created_at", "decision_basis", "readiness_effect", "unsafe_output_policy", "scenario_id", "dataset_hash", "repo_count", "finding_count", "duration_ms", "peak_memory_mb", "cache_hit_rate", "timeout_count", "budget_status", "sourceRefs"],
  "properties": {
    "record_type": {"const": "capacity-benchmark-run"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "scenario_id": {"type": "string"},
    "dataset_hash": {"type": "string"},
    "repo_count": {"type": "integer", "minimum": 0},
    "finding_count": {"type": "integer", "minimum": 0},
    "duration_ms": {"type": "integer", "minimum": 0},
    "peak_memory_mb": {"type": "integer", "minimum": 0},
    "cache_hit_rate": {"type": "number"},
    "timeout_count": {"type": "integer", "minimum": 0},
    "budget_status": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [{"required": ["actor"]}, {"required": ["system_actor"]}],
  "additionalProperties": true
}
