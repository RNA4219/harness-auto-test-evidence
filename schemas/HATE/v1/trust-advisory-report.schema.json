{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/trust-advisory-report.schema.json",
  "title": "HATE Trust Advisory Report",
  "type": "object",
  "required": ["schema_version", "record_type"],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {
      "enum": ["replay_report", "compare_report", "explain_report", "recommendation_report"]
    },
    "release_gate_override": {"const": false},
    "publish_gate_override": {"const": false}
  },
  "oneOf": [
    {
      "properties": {"record_type": {"const": "replay_report"}},
      "required": ["profile", "bundle_ref", "report_ref", "recalculation_hash", "deterministic_inputs", "weighted_score", "deterministic"]
    },
    {
      "properties": {"record_type": {"const": "compare_report"}},
      "required": ["base_ref", "head_ref", "trust_delta", "doctor_finding_delta", "dimension_delta", "signal_delta", "regression"]
    },
    {
      "properties": {"record_type": {"const": "explain_report"}},
      "required": ["mode", "bundle_ref", "report_ref", "reason_tree", "summary", "source_refs"]
    },
    {
      "properties": {"record_type": {"const": "recommendation_report"}},
      "required": ["gap_id", "bundle_ref", "report_ref", "recommendations", "summary", "source_refs"]
    }
  ],
  "additionalProperties": true
}
