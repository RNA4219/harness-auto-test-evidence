{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/adapter-family-report.schema.json",
  "title": "HATE Adapter Family Report",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "report_id",
    "overall_status",
    "readiness_effect",
    "required_family_count",
    "packet_count",
    "packets",
    "findings",
    "summary",
    "sourceRefs"
  ],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {"const": "adapter-family-report"},
    "report_id": {"type": "string"},
    "overall_status": {"type": "string", "enum": ["pass", "hold"]},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "required_family_count": {"type": "integer", "minimum": 0},
    "packet_count": {"type": "integer", "minimum": 0},
    "packets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "family",
          "adapter_id",
          "dialects",
          "fixture_paths",
          "positive_count",
          "negative_count",
          "malformed_count",
          "partial_count",
          "path_normalization_count",
          "metadata_preservation_count",
          "expected_output_ref",
          "reviewed_at",
          "review_owner",
          "stale_after_days",
          "unsupported_claims",
          "sourceRefs",
          "missing_fields"
        ],
        "additionalProperties": true
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message", "sourceRef", "readiness_effect"],
        "properties": {
          "code": {"type": "string"},
          "severity": {"type": "string"},
          "message": {"type": "string"},
          "sourceRef": {"type": "string"},
          "readiness_effect": {"type": "string", "enum": ["hold"]}
        },
        "additionalProperties": true
      }
    },
    "summary": {"type": "object", "additionalProperties": true},
    "sourceRefs": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
