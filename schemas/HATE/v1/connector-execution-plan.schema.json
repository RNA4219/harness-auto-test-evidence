{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/connector-execution-plan.schema.json",
  "title": "HATE Connector Execution Plan",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "plan_id",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "connector_id",
    "connector_type",
    "mode",
    "endpoint_ref",
    "idempotency_key",
    "payload_hash",
    "redaction_report_ref",
    "approval_required",
    "rollback_required",
    "steps",
    "findings",
    "summary",
    "sourceRefs"
  ],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {"const": "connector-execution-plan"},
    "plan_id": {"type": "string"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "connector_id": {"type": "string"},
    "connector_type": {"type": "string"},
    "mode": {"type": "string"},
    "endpoint_ref": {"type": "string"},
    "idempotency_key": {"type": "string"},
    "payload_hash": {"type": "string"},
    "redaction_report_ref": {"type": "string"},
    "approval_required": {"type": "boolean"},
    "rollback_required": {"type": "boolean"},
    "steps": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "findings": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "summary": {"type": "object", "additionalProperties": true},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
