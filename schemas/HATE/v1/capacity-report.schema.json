{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/capacity-report.schema.json",
  "title": "HATE Capacity Report",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "report_id",
    "overall_status",
    "readiness_effect",
    "benchmark_runs",
    "baseline_record",
    "degradation_report",
    "findings",
    "summary",
    "sourceRefs",
    "record_id",
    "created_at",
    "decision_basis",
    "unsafe_output_policy"
  ],
  "properties": {
    "schema_version": {
      "const": "HATE/v1"
    },
    "record_type": {
      "const": "capacity-report"
    },
    "report_id": {
      "type": "string"
    },
    "overall_status": {
      "type": "string",
      "enum": [
        "pass",
        "hold"
      ]
    },
    "readiness_effect": {
      "type": "string",
      "enum": [
        "none",
        "hold"
      ]
    },
    "benchmark_runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "record_type",
          "scenario_id",
          "dataset_hash",
          "repo_count",
          "finding_count",
          "duration_ms",
          "peak_memory_mb",
          "cache_hit_rate",
          "timeout_count",
          "degradation_mode",
          "budget_status"
        ],
        "properties": {
          "record_type": {
            "const": "capacity-benchmark-run"
          },
          "scenario_id": {
            "type": "string"
          },
          "dataset_hash": {
            "type": "string"
          },
          "repo_count": {
            "type": "integer"
          },
          "finding_count": {
            "type": "integer"
          },
          "duration_ms": {
            "type": "integer"
          },
          "peak_memory_mb": {
            "type": "integer"
          },
          "cache_hit_rate": {
            "type": "number"
          },
          "timeout_count": {
            "type": "integer"
          },
          "degradation_mode": {
            "type": "string"
          },
          "budget_status": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "baseline_record": {
      "type": "object",
      "required": [
        "record_type",
        "baseline_id",
        "machine_profile",
        "scenario_ids",
        "dataset_hashes",
        "run_count"
      ],
      "properties": {
        "record_type": {
          "const": "capacity-baseline-record"
        },
        "baseline_id": {
          "type": "string"
        },
        "machine_profile": {
          "type": "object",
          "additionalProperties": true
        },
        "scenario_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dataset_hashes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "run_count": {
          "type": "integer"
        }
      },
      "additionalProperties": true
    },
    "degradation_report": {
      "type": "object",
      "required": [
        "record_type",
        "degradation_modes",
        "budget_exceeded_scenarios",
        "timeout_count"
      ],
      "properties": {
        "record_type": {
          "const": "capacity-degradation-mode-report"
        },
        "degradation_modes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "budget_exceeded_scenarios": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "timeout_count": {
          "type": "integer"
        }
      },
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "severity",
          "message",
          "sourceRef",
          "readiness_effect"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "sourceRef": {
            "type": "string"
          },
          "readiness_effect": {
            "type": "string",
            "enum": [
              "hold"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "system_actor": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_basis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "unsafe_output_policy": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true,
  "anyOf": [
    {
      "required": [
        "actor"
      ]
    },
    {
      "required": [
        "system_actor"
      ]
    }
  ]
}
