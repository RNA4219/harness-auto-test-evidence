{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/environment-diff-report.schema.json",
  "title": "HATE Environment Diff Report",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "report_id",
    "overall_status",
    "readiness_effect",
    "diff_config",
    "findings",
    "summary",
    "environment_deltas",
    "attempts_compared",
    "drift_classes",
    "analysis_scope",
    "input_refs",
    "confidence",
    "limits",
    "sourceRefs"
  ],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {"const": "environment-diff-report"},
    "report_id": {"type": "string"},
    "overall_status": {"type": "string", "enum": ["pass", "hold", "blocked"]},
    "readiness_effect": {"type": "string", "enum": ["none", "hold", "blocked"]},
    "diff_config": {
      "type": "object",
      "required": ["environment_deltas", "attempts_compared", "drift_classes"],
      "properties": {
        "environment_deltas": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["delta_id", "delta_type", "category", "severity", "confidence", "sourceRef", "explained"],
            "properties": {
              "delta_id": {"type": "string"},
              "delta_type": {"type": "string"},
              "category": {"type": "string"},
              "severity": {"type": "string"},
              "confidence": {"type": "number", "minimum": 0, "maximum": 1},
              "sourceRef": {"type": "string"},
              "rationale": {"type": "string"},
              "explained": {"type": "boolean"}
            },
            "additionalProperties": true
          }
        },
        "attempts_compared": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["attempt_id", "environment_ref", "timestamp"],
            "properties": {
              "attempt_id": {"type": "string"},
              "environment_ref": {"type": "string"},
              "timestamp": {"type": "string"}
            },
            "additionalProperties": true
          }
        },
        "drift_classes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["class_id", "class_type", "drift_count", "severity"],
            "properties": {
              "class_id": {"type": "string"},
              "class_type": {"type": "string"},
              "drift_count": {"type": "integer", "minimum": 0},
              "severity": {"type": "string"}
            },
            "additionalProperties": true
          }
        },
        "runtime_version_drift_explained": {"type": "boolean"},
        "cache_state_known": {"type": "boolean"},
        "analysis_scope": {"type": "string"},
        "input_refs": {"type": "array", "items": {"type": "string"}},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "limits": {
          "type": "object",
          "required": ["max_deltas", "max_attempts", "max_drift_classes", "confidence_threshold"],
          "properties": {
            "max_deltas": {"type": "integer", "minimum": 0},
            "max_attempts": {"type": "integer", "minimum": 0},
            "max_drift_classes": {"type": "integer", "minimum": 0},
            "confidence_threshold": {"type": "number", "minimum": 0, "maximum": 1}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message", "sourceRef", "readiness_effect"],
        "properties": {
          "code": {"type": "string"},
          "severity": {"type": "string"},
          "message": {"type": "string"},
          "sourceRef": {"type": "string"},
          "readiness_effect": {"type": "string", "enum": ["hold", "blocked"]}
        },
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "object",
      "required": ["delta_count", "drift_class_count", "attempt_count", "confidence", "finding_count"],
      "properties": {
        "delta_count": {"type": "integer", "minimum": 0},
        "drift_class_count": {"type": "integer", "minimum": 0},
        "attempt_count": {"type": "integer", "minimum": 0},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "finding_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": true
    },
    "environment_deltas": {"type": "array", "items": {"type": "object"}},
    "attempts_compared": {"type": "array", "items": {"type": "object"}},
    "drift_classes": {"type": "array", "items": {"type": "object"}},
    "analysis_scope": {"type": "string"},
    "input_refs": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "limits": {
      "type": "object",
      "required": ["max_deltas", "max_attempts", "max_drift_classes", "confidence_threshold"],
      "properties": {
        "max_deltas": {"type": "integer", "minimum": 0},
        "max_attempts": {"type": "integer", "minimum": 0},
        "max_drift_classes": {"type": "integer", "minimum": 0},
        "confidence_threshold": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": true
    },
    "sourceRefs": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}