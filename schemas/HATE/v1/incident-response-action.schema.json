{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/incident-response-action.schema.json",
  "title": "HATE Incident Response Action",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "action_id",
    "status",
    "description",
    "required",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "incident-response-action"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "action_id": {"type": "string"},
    "status": {"type": "string", "enum": ["ready", "blocked"]},
    "description": {"type": "string"},
    "required": {"type": "boolean"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
