{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/operating-event-record.schema.json",
  "title": "HATE Operating Event Record",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "event_id",
    "sequence",
    "event_type",
    "operating_record_id",
    "entity_kind",
    "entity_id",
    "sourceRefs"
  ],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {"const": "operating-event-record"},
    "event_id": {"type": "string"},
    "sequence": {"type": "integer", "minimum": 1},
    "occurred_at": {"type": "string"},
    "event_type": {
      "type": "string",
      "enum": [
        "finding_opened",
        "finding_deduplicated",
        "owner_assigned",
        "due_date_changed",
        "manual_review_requested",
        "manual_review_decided",
        "risk_debt_accepted",
        "risk_debt_expired",
        "risk_debt_revoked",
        "risk_debt_resolved",
        "record_superseded",
        "tracker_sync_requested",
        "tracker_sync_completed",
        "tracker_sync_failed",
        "sla_breach_detected",
        "notification_requested",
        "notification_sent",
        "notification_failed",
        "projection_rebuilt",
        "retention_applied",
        "legal_hold_applied"
      ]
    },
    "operating_record_id": {"type": "string"},
    "entity_kind": {"type": "string", "enum": ["finding", "risk_debt", "manual_review", "policy_drift", "external_hold"]},
    "entity_id": {"type": "string"},
    "severity": {"type": "string"},
    "readiness_effect": {"type": "string"},
    "owner": {"type": "string"},
    "due_date": {"type": "string"},
    "expiry_date": {"type": "string"},
    "justification": {"type": "string"},
    "decision_basis": {"type": "array"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "superseding_record_id": {"type": "string"},
    "actor": {"type": "string"},
    "reason": {"type": "string"},
    "reviewer": {"type": "string"},
    "required_decision": {"type": "string"},
    "decision_reason": {"type": "string"},
    "blocking": {"type": "boolean"},
    "external_system": {"type": "string"},
    "external_ref": {"type": "string"},
    "external_status": {"type": "string"},
    "sync_direction": {"type": "string"},
    "sync_status": {"type": "string"},
    "last_synced_at": {"type": "string"},
    "sync_error": {"type": "string"},
    "delivery_target": {"type": "string"},
    "delivery_status": {"type": "string"},
    "attempt": {"type": "integer", "minimum": 0},
    "error_code": {"type": "string"},
    "retention_policy_id": {"type": "string"},
    "legal_hold_id": {"type": "string"},
    "rebuild_id": {"type": "string"},
    "previous_event_hash": {"type": "string"},
    "event_hash": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
