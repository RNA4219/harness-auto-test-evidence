{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/contradiction-report.schema.json",
  "title": "HATE Contradiction Report",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "report_id",
    "overall_status",
    "readiness_effect",
    "analysis_scope",
    "contradiction_config",
    "findings",
    "summary",
    "contradictions",
    "blocking_effects",
    "claim_impacts",
    "input_refs",
    "confidence",
    "limits",
    "sourceRefs"
  ],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {"const": "contradiction-report"},
    "report_id": {"type": "string"},
    "overall_status": {"type": "string", "enum": ["pass", "hold", "blocked"]},
    "readiness_effect": {"type": "string", "enum": ["none", "hold", "blocked"]},
    "analysis_scope": {"type": "string"},
    "contradiction_config": {
      "type": "object",
      "required": ["contradictions", "blocking_effects", "claim_impacts"],
      "properties": {
        "contradictions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["contradiction_id", "contradiction_type", "severity", "sourceRef"],
            "properties": {
              "contradiction_id": {"type": "string"},
              "contradiction_type": {"type": "string"},
              "severity": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
              "sourceRef": {"type": "string"},
              "rationale": {"type": "string"}
            },
            "additionalProperties": true
          }
        },
        "blocking_effects": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["effect_id", "effect_type", "blocked_claim"],
            "properties": {
              "effect_id": {"type": "string"},
              "effect_type": {"type": "string"},
              "blocked_claim": {"type": "string"},
              "sourceRef": {"type": "string"}
            },
            "additionalProperties": true
          }
        },
        "claim_impacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["claim_id", "impact_type", "impact_severity"],
            "properties": {
              "claim_id": {"type": "string"},
              "impact_type": {"type": "string"},
              "impact_severity": {"type": "string"},
              "sourceRef": {"type": "string"}
            },
            "additionalProperties": true
          }
        },
        "evidence_records": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "record_id": {"type": "string"},
              "record_type": {"type": "string"},
              "status": {"type": "string"},
              "readiness_effect": {"type": "string"},
              "severity": {"type": "string"},
              "finding_code": {"type": "string"},
              "requirement_ref": {"type": "string"},
              "claim_id": {"type": "string"},
              "metric_type": {"type": "string"},
              "current_value": {"type": "number"},
              "baseline_value": {"type": "number"},
              "schema_version": {"type": "string"},
              "expected_schema_version": {"type": "string"},
              "sourceRef": {"type": "string"}
            },
            "additionalProperties": true
          }
        },
        "release_claims": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "claim_id": {"type": "string"},
              "status": {"type": "string"},
              "evidence_refs": {"type": "array", "items": {"type": "string"}},
              "sourceRef": {"type": "string"}
            },
            "additionalProperties": true
          }
        },
        "pass_status_with_critical": {"type": "boolean"},
        "critical_finding_present": {"type": "boolean"},
        "coverage_mutation_aligned": {"type": "boolean"},
        "contract_schema_aligned": {"type": "boolean"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "input_refs": {"type": "array", "items": {"type": "string"}},
        "limits": {
          "type": "object",
          "required": ["confidence_threshold", "max_contradictions", "max_blocking_effects"],
          "properties": {
            "confidence_threshold": {"type": "number", "minimum": 0, "maximum": 1},
            "max_contradictions": {"type": "integer", "minimum": 0},
            "max_blocking_effects": {"type": "integer", "minimum": 0},
            "max_claim_impacts": {"type": "integer", "minimum": 0}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message", "sourceRef", "readiness_effect"],
        "properties": {
          "code": {"type": "string"},
          "severity": {"type": "string"},
          "message": {"type": "string"},
          "sourceRef": {"type": "string"},
          "readiness_effect": {"type": "string", "enum": ["hold", "blocked"]}
        },
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "object",
      "required": ["contradiction_count", "blocking_effect_count", "claim_impact_count", "confidence", "finding_count"],
      "properties": {
        "contradiction_count": {"type": "integer", "minimum": 0},
        "blocking_effect_count": {"type": "integer", "minimum": 0},
        "claim_impact_count": {"type": "integer", "minimum": 0},
        "evidence_record_count": {"type": "integer", "minimum": 0},
        "derived_contradiction_count": {"type": "integer", "minimum": 0},
        "blocked_claim_reference_count": {"type": "integer", "minimum": 0},
        "duplicate_contradiction_count": {"type": "integer", "minimum": 0},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "finding_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": true
    },
    "contradictions": {"type": "array", "items": {"type": "object"}},
    "blocking_effects": {"type": "array", "items": {"type": "object"}},
    "claim_impacts": {"type": "array", "items": {"type": "object"}},
    "evidence_records": {"type": "array", "items": {"type": "object"}},
    "release_claims": {"type": "array", "items": {"type": "object"}},
    "contradiction_diagnostics": {
      "type": "object",
      "required": [
        "derived_contradictions",
        "blocked_claim_refs",
        "duplicate_contradiction_ids",
        "missing_source_ref_ids"
      ],
      "properties": {
        "derived_contradictions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["contradiction_type", "subject_ref", "sourceRef"],
            "properties": {
              "contradiction_type": {"type": "string"},
              "subject_ref": {"type": "string"},
              "sourceRef": {"type": "string"}
            },
            "additionalProperties": true
          }
        },
        "blocked_claim_refs": {"type": "array", "items": {"type": "string"}},
        "duplicate_contradiction_ids": {"type": "array", "items": {"type": "string"}},
        "missing_source_ref_ids": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "input_refs": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "limits": {
      "type": "object",
      "required": ["confidence_threshold", "max_contradictions", "max_blocking_effects"],
      "properties": {
        "confidence_threshold": {"type": "number", "minimum": 0, "maximum": 1},
        "max_contradictions": {"type": "integer", "minimum": 0},
        "max_blocking_effects": {"type": "integer", "minimum": 0},
        "max_claim_impacts": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": true
    },
    "sourceRefs": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
