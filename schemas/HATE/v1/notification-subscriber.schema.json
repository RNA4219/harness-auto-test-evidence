{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/notification-subscriber.schema.json",
  "title": "HATE Notification Subscriber",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "subscriber_id",
    "owner",
    "team",
    "delivery_target",
    "target_ref",
    "routing_role",
    "active",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "notification-subscriber"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "subscriber_id": {"type": "string"},
    "owner": {"type": "string"},
    "team": {"type": "string"},
    "delivery_target": {"type": "string"},
    "target_ref": {"type": "string"},
    "routing_role": {"type": "string", "enum": ["primary", "escalation"]},
    "active": {"type": "boolean"},
    "sourceRef": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
