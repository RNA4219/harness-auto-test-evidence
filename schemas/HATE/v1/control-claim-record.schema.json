{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/control-claim-record.schema.json",
  "title": "HATE Control Claim Record",
  "type": "object",
  "required": ["record_type", "record_id", "created_at", "decision_basis", "readiness_effect", "unsafe_output_policy", "control_id", "claim_class", "claim_text", "evidence_refs", "expires_at", "supported", "sourceRefs"],
  "properties": {
    "record_type": {"const": "control-claim-record"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "control_id": {"type": "string"},
    "claim_class": {"type": "string"},
    "claim_text": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "expires_at": {"type": "string"},
    "supported": {"type": "boolean"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [{"required": ["actor"]}, {"required": ["system_actor"]}],
  "additionalProperties": true
}
