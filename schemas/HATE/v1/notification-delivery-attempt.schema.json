{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/notification-delivery-attempt.schema.json",
  "title": "HATE Notification Delivery Attempt",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "notification_id",
    "operating_record_id",
    "delivery_target",
    "target_ref",
    "dedupe_key",
    "payload_hash",
    "attempt",
    "max_attempts",
    "delivery_status",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "notification-delivery-attempt"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "notification_id": {"type": "string"},
    "operating_record_id": {"type": "string"},
    "delivery_target": {"type": "string"},
    "target_ref": {"type": "string"},
    "dedupe_key": {"type": "string"},
    "payload_hash": {"type": "string"},
    "attempt": {"type": "integer"},
    "max_attempts": {"type": "integer"},
    "next_retry_at": {"type": "string"},
    "delivery_status": {"type": "string"},
    "error_code": {"type": "string"},
    "signature_ref": {"type": "string"},
    "redaction_report_ref": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
