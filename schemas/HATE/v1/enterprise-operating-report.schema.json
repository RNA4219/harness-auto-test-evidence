{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/enterprise-operating-report.schema.json",
  "title": "HATE Enterprise Operating Report",
  "type": "object",
  "required": ["schema_version", "record_type"],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {
      "enum": [
        "release_migration_report",
        "entitlement_usage_report",
        "customer_docs_index",
        "incident_slo_report",
        "adoption_health_report",
        "security_trust_packet",
        "residency_deployment_report",
        "roadmap_decision_record",
        "accessibility_localization_report"
      ]
    },
    "run_id": {"type": "string"},
    "publish_gate_override": {"const": false}
  },
  "oneOf": [
    {"properties": {"record_type": {"const": "release_migration_report"}}, "required": ["run_id", "release_channel", "release_gates", "migration_artifacts", "compatibility_matrix"]},
    {"properties": {"record_type": {"const": "entitlement_usage_report"}}, "required": ["run_id", "edition", "entitlements", "usage", "over_limit_actions"]},
    {"properties": {"record_type": {"const": "customer_docs_index"}}, "required": ["docs", "overclaim_guard"]},
    {"properties": {"record_type": {"const": "incident_slo_report"}}, "required": ["run_id", "slo_targets", "incident_classes", "fixture_incidents"]},
    {"properties": {"record_type": {"const": "adoption_health_report"}}, "required": ["run_id", "stages", "adoption_gaps"]},
    {"properties": {"record_type": {"const": "security_trust_packet"}}, "required": ["run_id", "source_contract", "scope", "security_review_record", "trust_packet_refs", "control_mapping", "privacy_summary"]},
    {"properties": {"record_type": {"const": "residency_deployment_report"}}, "required": ["run_id", "deployment_modes", "residency_profile", "data_class_routing", "connectivity_controls", "backup_recovery", "summary"]},
    {"properties": {"record_type": {"const": "roadmap_decision_record"}}, "required": ["run_id", "roadmap_items", "decision_rationale", "customer_facing_available_claim"]},
    {"properties": {"record_type": {"const": "accessibility_localization_report"}}, "required": ["run_id", "surfaces", "message_catalog", "translated_schema_fields"]}
  ],
  "additionalProperties": true
}
