{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/history-analytics-report.schema.json",
  "title": "HATE History Analytics Report",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "report_id",
    "overall_status",
    "readiness_effect",
    "query",
    "trend_window",
    "result",
    "findings",
    "summary",
    "sourceRefs",
    "record_id",
    "created_at",
    "decision_basis",
    "unsafe_output_policy"
  ],
  "properties": {
    "schema_version": {
      "const": "HATE/v1"
    },
    "record_type": {
      "const": "history-analytics-report"
    },
    "report_id": {
      "type": "string"
    },
    "overall_status": {
      "type": "string",
      "enum": [
        "pass",
        "hold"
      ]
    },
    "readiness_effect": {
      "type": "string",
      "enum": [
        "none",
        "hold"
      ]
    },
    "query": {
      "type": "object",
      "required": [
        "record_type",
        "window_start",
        "window_end",
        "repo_filter",
        "suite_filter",
        "aggregation_level",
        "performance_budget_ms"
      ],
      "properties": {
        "record_type": {
          "const": "history-analytics-query"
        }
      },
      "additionalProperties": true
    },
    "trend_window": {
      "type": "object",
      "required": [
        "record_type",
        "window_start",
        "window_end",
        "repo_filter",
        "suite_filter",
        "aggregation_level",
        "sample_count",
        "excluded_count",
        "exclusion_reasons",
        "performance_budget_ms",
        "sourceRefs"
      ],
      "properties": {
        "record_type": {
          "const": "history-trend-window"
        }
      },
      "additionalProperties": true
    },
    "result": {
      "type": "object",
      "required": [
        "record_type",
        "metrics",
        "sample_count",
        "excluded_count",
        "exclusion_reasons",
        "sourceRefs"
      ],
      "properties": {
        "record_type": {
          "const": "history-analytics-result"
        }
      },
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "severity",
          "message",
          "sourceRef",
          "readiness_effect"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "sourceRef": {
            "type": "string"
          },
          "readiness_effect": {
            "type": "string",
            "enum": [
              "hold"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "system_actor": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_basis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "unsafe_output_policy": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true,
  "anyOf": [
    {
      "required": [
        "actor"
      ]
    },
    {
      "required": [
        "system_actor"
      ]
    }
  ]
}
