{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/compliance-evidence-pack.schema.json",
  "title": "HATE Compliance Evidence Pack",
  "type": "object",
  "required": ["record_type", "record_id", "created_at", "decision_basis", "readiness_effect", "unsafe_output_policy", "pack_id", "control_ids", "reviewed_control_ids", "customer_safe_export", "sourceRefs"],
  "properties": {
    "record_type": {"const": "compliance-evidence-pack"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "pack_id": {"type": "string"},
    "control_ids": {"type": "array", "items": {"type": "string"}},
    "reviewed_control_ids": {"type": "array", "items": {"type": "string"}},
    "customer_safe_export": {"type": "boolean"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [{"required": ["actor"]}, {"required": ["system_actor"]}],
  "additionalProperties": true
}
