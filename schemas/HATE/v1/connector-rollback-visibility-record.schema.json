{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/connector-rollback-visibility-record.schema.json",
  "title": "HATE Connector Rollback Visibility Record",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "connector_id",
    "external_ref",
    "rollback_available",
    "mode",
    "sync_status",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "connector-rollback-visibility-record"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "connector_id": {"type": "string"},
    "external_ref": {"type": "string"},
    "rollback_available": {"type": "boolean"},
    "mode": {"type": "string"},
    "sync_status": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
