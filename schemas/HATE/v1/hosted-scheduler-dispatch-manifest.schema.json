{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/hosted-scheduler-dispatch-manifest.schema.json",
  "title": "HATE Hosted Scheduler Dispatch Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "plan_id",
    "queue_id",
    "max_concurrency",
    "dispatch_entries",
    "sourceRefs",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy"
  ],
  "properties": {
    "schema_version": {
      "const": "HATE/v1"
    },
    "record_type": {
      "const": "hosted-scheduler-dispatch-manifest"
    },
    "plan_id": {
      "type": "string"
    },
    "queue_id": {
      "type": "string"
    },
    "max_concurrency": {
      "type": "integer",
      "minimum": 1
    },
    "dispatch_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "record_type",
          "dispatch_key",
          "queue_id",
          "shard_id",
          "job_id",
          "job_kind",
          "repo_id",
          "suite_id",
          "priority",
          "estimated_cost",
          "attempt",
          "max_attempts",
          "resume_required",
          "resume_token",
          "partial_result_ref",
          "sourceRefs"
        ],
        "properties": {
          "record_type": {
            "const": "hosted-scheduler-dispatch-entry"
          },
          "dispatch_key": {
            "type": "string"
          },
          "queue_id": {
            "type": "string"
          },
          "shard_id": {
            "type": "string"
          },
          "job_id": {
            "type": "string"
          },
          "job_kind": {
            "type": "string"
          },
          "repo_id": {
            "type": "string"
          },
          "suite_id": {
            "type": "string"
          },
          "priority": {
            "type": "integer"
          },
          "estimated_cost": {
            "type": "integer"
          },
          "attempt": {
            "type": "integer"
          },
          "max_attempts": {
            "type": "integer"
          },
          "resume_required": {
            "type": "boolean"
          },
          "resume_token": {
            "type": "string"
          },
          "partial_result_ref": {
            "type": "string"
          },
          "sourceRefs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "system_actor": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_basis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "readiness_effect": {
      "type": "string",
      "enum": [
        "none",
        "hold"
      ]
    },
    "unsafe_output_policy": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true,
  "anyOf": [
    {
      "required": [
        "actor"
      ]
    },
    {
      "required": [
        "system_actor"
      ]
    }
  ]
}
