{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/real-repo-roster-execution-manifest.schema.json",
  "title": "HATE Real Repo Roster Execution Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "manifest_id",
    "generated_at",
    "entries",
    "findings",
    "summary",
    "sourceRefs",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy"
  ],
  "properties": {
    "schema_version": {
      "const": "HATE/v1"
    },
    "record_type": {
      "const": "real-repo-roster-execution-manifest"
    },
    "manifest_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "record_type",
          "sequence",
          "repo_id",
          "ownership_scope",
          "repo_class",
          "suite_ids",
          "execution_action",
          "retry_isolation_group",
          "bootstrap_required",
          "bootstrap_status",
          "dependency_bootstrap_command",
          "scheduler_job_id",
          "sourceRefs"
        ],
        "properties": {
          "record_type": {
            "const": "real-repo-roster-execution-entry"
          },
          "sequence": {
            "type": "integer"
          },
          "repo_id": {
            "type": "string"
          },
          "ownership_scope": {
            "type": "string",
            "enum": [
              "owned",
              "external"
            ]
          },
          "repo_class": {
            "type": "string"
          },
          "suite_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "execution_action": {
            "type": "string",
            "enum": [
              "run",
              "quarantine",
              "external_hold"
            ]
          },
          "retry_isolation_group": {
            "type": "string"
          },
          "bootstrap_required": {
            "type": "boolean"
          },
          "bootstrap_status": {
            "type": "string"
          },
          "dependency_bootstrap_command": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "scheduler_job_id": {
            "type": "string"
          },
          "sourceRefs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "severity",
          "message",
          "sourceRef",
          "readiness_effect"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "sourceRef": {
            "type": "string"
          },
          "readiness_effect": {
            "type": "string",
            "enum": [
              "hold"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "entry_count",
        "maintain_count",
        "quarantine_count",
        "external_hold_count",
        "bootstrap_required_count",
        "finding_count",
        "ready_for_scheduler"
      ],
      "additionalProperties": true
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "system_actor": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_basis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "readiness_effect": {
      "type": "string",
      "enum": [
        "none",
        "hold"
      ]
    },
    "unsafe_output_policy": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true,
  "anyOf": [
    {
      "required": [
        "actor"
      ]
    },
    {
      "required": [
        "system_actor"
      ]
    }
  ]
}
