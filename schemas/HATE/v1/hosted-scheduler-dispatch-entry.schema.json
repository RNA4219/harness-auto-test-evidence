{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/hosted-scheduler-dispatch-entry.schema.json",
  "title": "HATE Hosted Scheduler Dispatch Entry",
  "type": "object",
  "required": ["record_type", "record_id", "created_at", "decision_basis", "readiness_effect", "unsafe_output_policy", "dispatch_key", "queue_id", "shard_id", "job_id", "job_kind", "sourceRefs"],
  "properties": {
    "record_type": {"const": "hosted-scheduler-dispatch-entry"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "dispatch_key": {"type": "string"},
    "queue_id": {"type": "string"},
    "shard_id": {"type": "string"},
    "job_id": {"type": "string"},
    "job_kind": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [{"required": ["actor"]}, {"required": ["system_actor"]}],
  "additionalProperties": true
}
