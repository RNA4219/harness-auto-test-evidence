{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/store-restore-operation.schema.json",
  "title": "HATE Store Restore Operation",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "backup_id",
    "restore_hash",
    "restore_status",
    "legal_hold_count_after",
    "rpo_seconds",
    "rto_seconds",
    "projection_rebuild_status",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "store-restore-operation"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "backup_id": {"type": "string"},
    "restore_hash": {"type": "string"},
    "restore_status": {"type": "string"},
    "legal_hold_count_after": {"type": "integer"},
    "rpo_seconds": {"type": "integer"},
    "rto_seconds": {"type": "integer"},
    "projection_rebuild_status": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
