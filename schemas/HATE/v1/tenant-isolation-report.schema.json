{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/tenant-isolation-report.schema.json",
  "title": "HATE Tenant Isolation Report",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "source_version",
    "fixture_id",
    "gap_id",
    "status",
    "readiness_effect",
    "decision_id",
    "audit_events",
    "sanitized_payload",
    "sourceRefs"
  ],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {"const": "tenant-isolation-report"},
    "source_version": {"type": "string"},
    "fixture_id": {"type": ["string", "null"]},
    "gap_id": {"type": "string"},
    "status": {"enum": ["pass", "hold"]},
    "readiness_effect": {"enum": ["none", "hold"]},
    "finding_code": {"type": "string"},
    "decision_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "audit_events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "tenant_id",
          "actor_id",
          "role",
          "action",
          "resource_ref",
          "decision",
          "message",
          "event_hash"
        ],
        "properties": {
          "tenant_id": {"type": "string"},
          "actor_id": {"type": "string"},
          "role": {"type": "string"},
          "action": {"type": "string"},
          "resource_ref": {"type": "string"},
          "decision": {"enum": ["allow", "deny"]},
          "message": {"type": "string"},
          "finding_code": {"type": "string"},
          "event_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
        },
        "additionalProperties": true
      }
    },
    "sanitized_payload": {"type": "object"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
