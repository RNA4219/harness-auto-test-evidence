{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/procurement-questionnaire-export.schema.json",
  "title": "HATE Procurement Questionnaire Export",
  "type": "object",
  "required": ["record_type", "record_id", "created_at", "decision_basis", "readiness_effect", "unsafe_output_policy", "export_id", "customer_safe_export", "restricted_data_present", "answered_control_ids", "sourceRefs"],
  "properties": {
    "record_type": {"const": "procurement-questionnaire-export"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "export_id": {"type": "string"},
    "customer_safe_export": {"type": "boolean"},
    "restricted_data_present": {"type": "boolean"},
    "answered_control_ids": {"type": "array", "items": {"type": "string"}},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [{"required": ["actor"]}, {"required": ["system_actor"]}],
  "additionalProperties": true
}
