{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/history-incremental-materialization.schema.json",
  "title": "HATE History Incremental Materialization",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "strategy",
    "reused_count",
    "recompute_count",
    "drop_count",
    "excluded_count",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "history-incremental-materialization"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "strategy": {"type": "string"},
    "reused_count": {"type": "integer"},
    "recompute_count": {"type": "integer"},
    "drop_count": {"type": "integer"},
    "excluded_count": {"type": "integer"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
