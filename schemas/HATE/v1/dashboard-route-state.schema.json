{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/dashboard-route-state.schema.json",
  "title": "HATE Dashboard Route State",
  "type": "object",
  "required": ["record_type", "record_id", "created_at", "decision_basis", "readiness_effect", "unsafe_output_policy", "route", "ui_state", "read_model_ref", "rbac_decision", "sourceRefs"],
  "properties": {
    "record_type": {"const": "dashboard-route-state"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "route": {"type": "string"},
    "ui_state": {"type": "string"},
    "read_model_ref": {"type": "string"},
    "rbac_decision": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [{"required": ["actor"]}, {"required": ["system_actor"]}],
  "additionalProperties": true
}
