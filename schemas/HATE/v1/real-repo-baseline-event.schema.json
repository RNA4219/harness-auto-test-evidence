{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/real-repo-baseline-event.schema.json",
  "title": "HATE Real Repository Baseline Event",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "baseline_id",
    "repo_id",
    "suite_id",
    "baseline_run_id",
    "event_type",
    "actor",
    "reason",
    "policy_hash",
    "sourceRefs"
  ],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {"const": "real-repo-baseline-event"},
    "baseline_id": {"type": "string"},
    "repo_id": {"type": "string"},
    "suite_id": {"type": "string"},
    "baseline_run_id": {"type": "string"},
    "event_type": {"type": "string", "enum": ["proposed", "approved", "frozen", "expired", "revoked", "superseded"]},
    "actor": {"type": "string"},
    "reason": {"type": "string"},
    "approved_by": {"type": "string"},
    "expires_at": {"type": "string"},
    "policy_hash": {"type": "string"},
    "ownership_scope": {"type": "string", "enum": ["owned", "external", "third_party_sample"]},
    "sourceRefs": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
