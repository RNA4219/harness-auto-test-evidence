{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/store-backup-operation.schema.json",
  "title": "HATE Store Backup Operation",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "backup_id",
    "backup_manifest_ref",
    "source_store_hash",
    "backup_hash",
    "legal_hold_count_before",
    "corruption_scan_result",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "store-backup-operation"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "backup_id": {"type": "string"},
    "backup_manifest_ref": {"type": "string"},
    "source_store_hash": {"type": "string"},
    "backup_hash": {"type": "string"},
    "legal_hold_count_before": {"type": "integer"},
    "corruption_scan_result": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
