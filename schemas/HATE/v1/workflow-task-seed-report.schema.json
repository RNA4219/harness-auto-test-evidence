{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/workflow-task-seed-report.schema.json",
  "title": "HATE Workflow Task Seed Report",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "report_id",
    "overall_status",
    "readiness_effect",
    "task_seed",
    "findings",
    "summary",
    "sourceRefs"
  ],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {"const": "workflow-task-seed-report"},
    "report_id": {"type": "string"},
    "overall_status": {"type": "string", "enum": ["pass", "hold"]},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "task_seed": {
      "type": "object",
      "required": [
        "task_id",
        "objective",
        "scope",
        "requirements",
        "commands",
        "dependencies",
        "slice_days",
        "packet_size_days",
        "seed_slices",
        "changes_generated_artifacts",
        "birdseye_update",
        "status",
        "acceptance_record",
        "exception_reason"
      ],
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message", "sourceRef", "readiness_effect"],
        "properties": {
          "code": {"type": "string"},
          "severity": {"type": "string"},
          "message": {"type": "string"},
          "sourceRef": {"type": "string"},
          "readiness_effect": {"type": "string", "enum": ["hold"]}
        },
        "additionalProperties": true
      }
    },
    "summary": {"type": "object", "additionalProperties": true},
    "sourceRefs": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
