{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/real-repo-environment-recipe.schema.json",
  "title": "HATE Real Repo Environment Recipe",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "repo_id",
    "environment_recipe_ref",
    "dependency_bootstrap_command",
    "bootstrap_status",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "real-repo-environment-recipe"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "repo_id": {"type": "string"},
    "environment_recipe_ref": {"type": "string"},
    "dependency_bootstrap_command": {"type": "array", "items": {"type": "string"}},
    "bootstrap_status": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
