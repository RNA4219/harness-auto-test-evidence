{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/capacity-regression-comparison.schema.json",
  "title": "HATE Capacity Regression Comparison",
  "type": "object",
  "required": ["record_type", "record_id", "created_at", "decision_basis", "readiness_effect", "unsafe_output_policy", "scenario_id", "comparison_status", "regression_detected", "regression_reasons", "sourceRefs"],
  "properties": {
    "record_type": {"const": "capacity-regression-comparison"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "scenario_id": {"type": "string"},
    "comparison_status": {"type": "string"},
    "regression_detected": {"type": "boolean"},
    "regression_reasons": {"type": "array", "items": {"type": "string"}},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [{"required": ["actor"]}, {"required": ["system_actor"]}],
  "additionalProperties": true
}
