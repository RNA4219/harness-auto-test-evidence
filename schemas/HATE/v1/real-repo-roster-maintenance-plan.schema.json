{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/real-repo-roster-maintenance-plan.schema.json",
  "title": "HATE Real Repo Roster Maintenance Plan",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "repo_id",
    "ownership_scope",
    "repo_class",
    "suite_ids",
    "discovery_source",
    "last_seen_at",
    "stale_after",
    "retry_isolation_group",
    "external_repair_allowed",
    "action",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "real-repo-roster-maintenance-plan"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "repo_id": {"type": "string"},
    "ownership_scope": {"type": "string"},
    "repo_class": {"type": "string"},
    "suite_ids": {"type": "array", "items": {"type": "string"}},
    "discovery_source": {"type": "string"},
    "last_seen_at": {"type": "string"},
    "stale_after": {"type": "string"},
    "retry_isolation_group": {"type": "string"},
    "external_repair_allowed": {"type": "boolean"},
    "action": {"type": "string", "enum": ["maintain", "quarantine", "external_hold"]},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
