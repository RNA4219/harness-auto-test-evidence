{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/platform-policy-report.schema.json",
  "title": "HATE Platform Policy Report",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "report_id",
    "overall_status",
    "readiness_effect",
    "policy_id",
    "policy_version",
    "profile",
    "policy_hash",
    "effective_profile",
    "resolved_thresholds",
    "plugin_trust_decision",
    "retention_decision",
    "scheduler_decision",
    "findings",
    "summary",
    "sourceRefs"
  ],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {"const": "platform-policy-report"},
    "report_id": {"type": "string"},
    "overall_status": {"type": "string", "enum": ["pass", "hold"]},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "policy_id": {"type": "string"},
    "policy_version": {"type": "string"},
    "profile": {"type": "string"},
    "policy_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "effective_profile": {"type": "object"},
    "resolved_thresholds": {"type": "array"},
    "plugin_trust_decision": {"type": "object"},
    "retention_decision": {"type": "object"},
    "scheduler_decision": {"type": "object"},
    "findings": {"type": "array"},
    "summary": {"type": "object"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
