{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/hosted-api-route-contract.schema.json",
  "title": "HATE Hosted API Route Contract",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "operation_id",
    "method",
    "path",
    "resource",
    "action",
    "required_scope",
    "tenant_scoped",
    "audit_required",
    "rate_limited",
    "description",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "hosted-api-route-contract"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "operation_id": {"type": "string"},
    "method": {"type": "string"},
    "path": {"type": "string"},
    "resource": {"type": "string"},
    "action": {"type": "string", "enum": ["read", "write"]},
    "required_scope": {"type": "string"},
    "tenant_scoped": {"type": "boolean"},
    "audit_required": {"type": "boolean"},
    "rate_limited": {"type": "boolean"},
    "description": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
