{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/hosted-api-request-record.schema.json",
  "title": "HATE Hosted API Request Record",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "request_id",
    "tenant_id",
    "resource_tenant_id",
    "subject_id",
    "role",
    "auth_method",
    "resource",
    "action",
    "token_ref",
    "token_expiry",
    "required_scope",
    "rate_limit_bucket",
    "rate_limit_status",
    "audit_event_present",
    "restricted_data_leaked",
    "safe_denial_response",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "hosted-api-request-record"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "request_id": {"type": "string"},
    "tenant_id": {"type": "string"},
    "resource_tenant_id": {"type": "string"},
    "subject_id": {"type": "string"},
    "role": {"type": "string"},
    "auth_method": {"type": "string"},
    "resource": {"type": "string"},
    "action": {"type": "string"},
    "token_ref": {"type": "string"},
    "raw_token": {"type": "string"},
    "token_expiry": {"type": "string"},
    "service_account_scopes": {"type": "array", "items": {"type": "string"}},
    "required_scope": {"type": "string"},
    "rate_limit_bucket": {"type": "string"},
    "rate_limit_status": {"type": "string"},
    "audit_event_present": {"type": "boolean"},
    "restricted_data_leaked": {"type": "boolean"},
    "safe_denial_response": {"type": "boolean"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
