{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/hosted-authz-decision-record.schema.json",
  "title": "HATE Hosted Authz Decision Record",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "request_id",
    "tenant_id",
    "subject_id",
    "role",
    "auth_method",
    "resource",
    "action",
    "decision",
    "denial_reason",
    "token_ref",
    "token_expiry",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "hosted-authz-decision-record"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "request_id": {"type": "string"},
    "tenant_id": {"type": "string"},
    "subject_id": {"type": "string"},
    "role": {"type": "string"},
    "auth_method": {"type": "string"},
    "resource": {"type": "string"},
    "action": {"type": "string"},
    "decision": {"type": "string", "enum": ["allowed", "denied"]},
    "denial_reason": {"type": "string"},
    "token_ref": {"type": "string"},
    "token_expiry": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
