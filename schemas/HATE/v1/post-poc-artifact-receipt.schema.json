{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/post-poc-artifact-receipt.schema.json",
  "title": "HATE Post-PoC Artifact Receipt",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "artifact_path",
    "sourceRefs"
  ],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {
      "type": "string",
      "enum": [
        "post-poc-artifact-receipt",
        "baseline-review-packet-artifact",
        "capacity-regression-packet-artifact",
        "connector-execution-manifest-artifact",
        "dashboard-static-html-artifact",
        "history-materialization-manifest-artifact",
        "hosted-api-openapi-artifact",
        "hosted-scheduler-dispatch-manifest-artifact",
        "human-review-queue-packet-artifact",
        "incident-response-packet-artifact",
        "notification-routing-manifest-artifact",
        "plugin-install-manifest-artifact",
        "real-repo-roster-execution-manifest-artifact",
        "store-dr-runbook-artifact"
      ]
    },
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "tenant_id": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "artifact_path": {"type": "string", "minLength": 1},
    "sourceRefs": {"type": "array", "items": {"type": "string"}}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
