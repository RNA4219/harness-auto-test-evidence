{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/baseline-review-comparison.schema.json",
  "title": "HATE Baseline Review Comparison",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "previous_baseline_ref",
    "previous_score",
    "candidate_score",
    "score_delta",
    "previous_regression_count",
    "candidate_regression_count",
    "regression_count_delta",
    "comparison_artifact_ref",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "baseline-review-comparison"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "previous_baseline_ref": {"type": "string"},
    "previous_score": {"type": ["number", "null"]},
    "candidate_score": {"type": ["number", "null"]},
    "score_delta": {"type": ["number", "null"]},
    "previous_regression_count": {"type": "integer"},
    "candidate_regression_count": {"type": "integer"},
    "regression_count_delta": {"type": "integer"},
    "comparison_artifact_ref": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
