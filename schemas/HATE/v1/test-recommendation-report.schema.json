{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/test-recommendation-report.schema.json",
  "title": "HATE Test Recommendation Report",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "report_id",
    "overall_status",
    "readiness_effect",
    "recommendation_config",
    "findings",
    "summary",
    "derived_recommendations",
    "test_recommendation_diagnostics",
    "analysis_scope",
    "input_refs",
    "confidence",
    "limits",
    "sourceRefs"
  ],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {"const": "test-recommendation-report"},
    "report_id": {"type": "string"},
    "overall_status": {"type": "string", "enum": ["pass", "hold", "blocked"]},
    "readiness_effect": {"type": "string", "enum": ["none", "hold", "blocked"]},
    "recommendation_config": {
      "type": "object",
      "required": ["recommendations", "required_oracles", "verification_commands", "signals"],
      "properties": {
        "recommendations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["recommendation_id", "action", "target", "risk_id", "required_oracle_id", "confidence", "sourceRef", "rationale", "actionable"],
            "properties": {
              "recommendation_id": {"type": "string"},
              "action": {"type": "string"},
              "target": {"type": "string"},
              "risk_id": {"type": "string"},
              "required_oracle_id": {"type": "string"},
              "confidence": {"type": "number", "minimum": 0, "maximum": 1},
              "sourceRef": {"type": "string"},
              "rationale": {"type": "string"},
              "actionable": {"type": "boolean"}
            },
            "additionalProperties": true
          }
        },
        "required_oracles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["oracle_id", "risk_id", "confidence", "sourceRef", "rationale", "verified"],
            "properties": {
              "oracle_id": {"type": "string"},
              "risk_id": {"type": "string"},
              "confidence": {"type": "number", "minimum": 0, "maximum": 1},
              "sourceRef": {"type": "string"},
              "rationale": {"type": "string"},
              "verified": {"type": "boolean"}
            },
            "additionalProperties": true
          }
        },
        "verification_commands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["command_id", "recommendation_id", "confidence", "sourceRef", "rationale", "verified"],
            "properties": {
              "command_id": {"type": "string"},
              "recommendation_id": {"type": "string"},
              "confidence": {"type": "number", "minimum": 0, "maximum": 1},
              "sourceRef": {"type": "string"},
              "rationale": {"type": "string"},
              "verified": {"type": "boolean"}
            },
            "additionalProperties": true
          }
        },
        "signals": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["signal_id", "signal_type", "risk_id", "test_id", "requirement_id", "severity", "readiness_effect", "sourceRef"],
            "properties": {
              "signal_id": {"type": "string"},
              "signal_type": {"type": "string"},
              "risk_id": {"type": "string"},
              "test_id": {"type": "string"},
              "requirement_id": {"type": "string"},
              "severity": {"type": "string"},
              "readiness_effect": {"type": "string"},
              "sourceRef": {"type": "string"}
            },
            "additionalProperties": true
          }
        },
        "analysis_scope": {"type": "string"},
        "input_refs": {"type": "array", "items": {"type": "string"}},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "limits": {
          "type": "object",
          "required": ["max_recommendations", "max_oracles", "max_commands", "confidence_threshold"],
          "properties": {
            "max_recommendations": {"type": "integer", "minimum": 0},
            "max_oracles": {"type": "integer", "minimum": 0},
            "max_commands": {"type": "integer", "minimum": 0},
            "confidence_threshold": {"type": "number", "minimum": 0, "maximum": 1}
          },
          "additionalProperties": true
        },
        "actionable_taxonomy_used": {"type": "boolean"},
        "oracle_validation_enabled": {"type": "boolean"},
        "command_verification_enabled": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message", "sourceRef", "readiness_effect"],
        "properties": {
          "code": {"type": "string"},
          "severity": {"type": "string"},
          "message": {"type": "string"},
          "sourceRef": {"type": "string"},
          "readiness_effect": {"type": "string", "enum": ["hold", "blocked"]}
        },
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "recommendation_count",
        "required_oracle_count",
        "verification_command_count",
        "signal_count",
        "derived_recommendation_count",
        "missing_command_count",
        "missing_oracle_count",
        "confidence",
        "finding_count"
      ],
      "properties": {
        "recommendation_count": {"type": "integer", "minimum": 0},
        "required_oracle_count": {"type": "integer", "minimum": 0},
        "verification_command_count": {"type": "integer", "minimum": 0},
        "signal_count": {"type": "integer", "minimum": 0},
        "derived_recommendation_count": {"type": "integer", "minimum": 0},
        "missing_command_count": {"type": "integer", "minimum": 0},
        "missing_oracle_count": {"type": "integer", "minimum": 0},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "finding_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": true
    },
    "derived_recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["recommendation_id", "action", "target", "risk_id", "required_oracle", "verification_command", "confidence", "sourceRef"],
        "properties": {
          "recommendation_id": {"type": "string"},
          "action": {"type": "string"},
          "target": {"type": "string"},
          "risk_id": {"type": "string"},
          "required_oracle": {"type": "string"},
          "verification_command": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "sourceRef": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "test_recommendation_diagnostics": {
      "type": "object",
      "required": [
        "derived_recommendations",
        "recommendations_missing_command",
        "recommendations_missing_oracle",
        "missing_source_ref_ids",
        "stale_or_generic_recommendation_ids"
      ],
      "properties": {
        "derived_recommendations": {"type": "array"},
        "recommendations_missing_command": {"type": "array", "items": {"type": "string"}},
        "recommendations_missing_oracle": {"type": "array", "items": {"type": "string"}},
        "missing_source_ref_ids": {"type": "array", "items": {"type": "string"}},
        "stale_or_generic_recommendation_ids": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "analysis_scope": {"type": "string"},
    "input_refs": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "limits": {
      "type": "object",
      "required": ["max_recommendations", "max_oracles", "max_commands", "confidence_threshold"],
      "properties": {
        "max_recommendations": {"type": "integer", "minimum": 0},
        "max_oracles": {"type": "integer", "minimum": 0},
        "max_commands": {"type": "integer", "minimum": 0},
        "confidence_threshold": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": true
    },
    "sourceRefs": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
