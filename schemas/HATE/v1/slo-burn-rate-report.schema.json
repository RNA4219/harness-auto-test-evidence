{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/slo-burn-rate-report.schema.json",
  "title": "HATE SLO Burn Rate Report",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "correlation_id",
    "run_id",
    "tenant_id",
    "service_name",
    "metric_name",
    "slo_id",
    "burn_rate",
    "alert_status",
    "alert_route_ref",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "slo-burn-rate-report"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "correlation_id": {"type": "string"},
    "run_id": {"type": "string"},
    "tenant_id": {"type": "string"},
    "service_name": {"type": "string"},
    "metric_name": {"type": "string"},
    "slo_id": {"type": "string"},
    "burn_rate": {"type": "number", "minimum": 0},
    "alert_status": {"type": "string"},
    "alert_route_ref": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
