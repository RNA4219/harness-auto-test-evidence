{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/dashboard-action-intent.schema.json",
  "title": "HATE Dashboard Action Intent",
  "type": "object",
  "required": ["record_type", "record_id", "created_at", "decision_basis", "readiness_effect", "unsafe_output_policy", "intent_id", "action_type", "actor", "target_ref", "idempotency_key", "intent_status", "sourceRefs"],
  "properties": {
    "record_type": {"const": "dashboard-action-intent"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "intent_id": {"type": "string"},
    "action_type": {"type": "string"},
    "target_ref": {"type": "string"},
    "idempotency_key": {"type": "string"},
    "intent_status": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [{"required": ["actor"]}, {"required": ["system_actor"]}],
  "additionalProperties": true
}
