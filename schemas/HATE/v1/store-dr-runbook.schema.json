{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/store-dr-runbook.schema.json",
  "title": "HATE Store DR Runbook",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "runbook_id",
    "backup_id",
    "restore_status",
    "steps",
    "findings",
    "summary",
    "sourceRefs",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy"
  ],
  "properties": {
    "schema_version": {
      "const": "HATE/v1"
    },
    "record_type": {
      "const": "store-dr-runbook"
    },
    "runbook_id": {
      "type": "string"
    },
    "backup_id": {
      "type": "string"
    },
    "restore_status": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "record_type",
          "step_id",
          "status",
          "description",
          "required"
        ],
        "properties": {
          "record_type": {
            "const": "store-dr-runbook-step"
          },
          "step_id": {
            "type": "string",
            "enum": [
              "verify_backup_inventory",
              "verify_backup_hash",
              "verify_corruption_scan",
              "restore_store",
              "verify_legal_hold",
              "verify_rpo",
              "verify_rto",
              "rebuild_projection"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "ready",
              "blocked"
            ]
          },
          "description": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "severity",
          "message",
          "sourceRef",
          "readiness_effect"
        ],
        "properties": {
          "code": {
            "type": "string",
            "enum": [
              "dr_runbook_step_blocked",
              "dr_runbook_blocked_by_report_findings"
            ]
          },
          "severity": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "sourceRef": {
            "type": "string"
          },
          "readiness_effect": {
            "type": "string",
            "enum": [
              "hold"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "step_count",
        "ready_step_count",
        "blocked_step_count",
        "finding_count",
        "ready_for_restore"
      ],
      "properties": {
        "step_count": {
          "type": "integer"
        },
        "ready_step_count": {
          "type": "integer"
        },
        "blocked_step_count": {
          "type": "integer"
        },
        "finding_count": {
          "type": "integer"
        },
        "ready_for_restore": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "system_actor": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_basis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "readiness_effect": {
      "type": "string",
      "enum": [
        "none",
        "hold"
      ]
    },
    "unsafe_output_policy": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true,
  "anyOf": [
    {
      "required": [
        "actor"
      ]
    },
    {
      "required": [
        "system_actor"
      ]
    }
  ]
}
