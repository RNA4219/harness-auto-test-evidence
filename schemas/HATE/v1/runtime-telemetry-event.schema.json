{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/runtime-telemetry-event.schema.json",
  "title": "HATE Runtime Telemetry Event",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "signal",
    "correlation_id",
    "run_id",
    "tenant_id",
    "service_name",
    "metric_name",
    "log_message",
    "trace_id",
    "alert_route_ref",
    "redaction_report_ref",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "runtime-telemetry-event"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "signal": {"type": "string"},
    "correlation_id": {"type": "string"},
    "run_id": {"type": "string"},
    "tenant_id": {"type": "string"},
    "service_name": {"type": "string"},
    "metric_name": {"type": "string"},
    "log_message": {"type": "string"},
    "trace_id": {"type": "string"},
    "alert_route_ref": {"type": "string"},
    "redaction_report_ref": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
