{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/worker-runtime-report.schema.json",
  "title": "HATE Worker Runtime Report",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "source_version",
    "fixture_id",
    "gap_id",
    "status",
    "readiness_effect",
    "job",
    "sourceRefs"
  ],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {"const": "worker-runtime-report"},
    "source_version": {"type": "string"},
    "fixture_id": {"type": ["string", "null"]},
    "gap_id": {"type": "string"},
    "status": {"enum": ["pass", "hold"]},
    "readiness_effect": {"enum": ["none", "hold"]},
    "finding_code": {"type": "string"},
    "job": {
      "type": "object",
      "required": [
        "job_id",
        "tenant_id",
        "kind",
        "status",
        "idempotency_key",
        "attempts",
        "worker_events",
        "audit_events",
        "artifacts",
        "findings"
      ],
      "properties": {
        "job_id": {"type": "string"},
        "tenant_id": {"type": "string"},
        "kind": {"type": "string"},
        "status": {
          "enum": [
            "queued",
            "leased",
            "running",
            "retry_wait",
            "succeeded",
            "succeeded_with_quarantine",
            "failed",
            "poison",
            "cancelling",
            "cancelled"
          ]
        },
        "idempotency_key": {"type": "string"},
        "attempts": {"type": "integer", "minimum": 0},
        "worker_events": {"type": "array", "items": {"type": "string"}},
        "audit_events": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["event_type", "message", "source"],
            "properties": {
              "event_type": {"type": "string"},
              "message": {"type": "string"},
              "source": {"type": "string"}
            },
            "additionalProperties": true
          }
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["artifact_id", "job_id", "hash", "safety_status", "retention_class"],
            "properties": {
              "artifact_id": {"type": "string"},
              "job_id": {"type": "string"},
              "hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
              "safety_status": {"type": "string"},
              "retention_class": {"type": "string"}
            },
            "additionalProperties": true
          }
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["code", "severity", "message"],
            "properties": {
              "code": {"type": "string"},
              "severity": {"type": "string"},
              "message": {"type": "string"}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "sourceRefs": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
