{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/human-review-workflow-decision.schema.json",
  "title": "HATE Human Review Workflow Decision",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "review_id",
    "decision",
    "decision_reason",
    "reviewer",
    "owner",
    "evidence_refs",
    "previous_decision_ref",
    "superseded_by",
    "decision_hash",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "human-review-workflow-decision"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "review_id": {"type": "string"},
    "decision": {"type": "string"},
    "decision_reason": {"type": "string"},
    "reviewer": {"type": "string"},
    "owner": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "previous_decision_ref": {"type": "string"},
    "superseded_by": {"type": "string"},
    "decision_hash": {"type": "string"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
