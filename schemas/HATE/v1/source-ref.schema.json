{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quality-harness.dev/schemas/hate/v1/source-ref.schema.json",
  "title": "HATE v1 Source Reference",
  "type": "object",
  "required": [
    "artifact_id",
    "path",
    "normalized_path",
    "content_hash",
    "source_family"
  ],
  "properties": {
    "artifact_id": { "type": "string", "minLength": 1 },
    "path": { "type": "string", "minLength": 1 },
    "normalized_path": { "type": "string", "minLength": 1 },
    "content_hash": { "type": "string", "pattern": "^sha256:[A-Fa-f0-9]{64}$" },
    "line": { "type": "integer", "minimum": 1 },
    "column": { "type": "integer", "minimum": 1 },
    "end_line": { "type": "integer", "minimum": 1 },
    "end_column": { "type": "integer", "minimum": 1 },
    "context_id": { "type": "string" },
    "source_family": {
      "enum": ["source", "test", "fixture", "schema", "doc", "artifact"]
    }
  },
  "additionalProperties": true
}
