{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quality-harness.dev/schemas/hate/v1/contract-evidence.schema.json",
  "title": "HATE v1 Contract Evidence Record",
  "allOf": [
    { "$ref": "common-envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "record_type": { "const": "contract_evidence" },
        "payload": {
          "type": "object",
          "required": ["contract_id", "provider", "consumer", "interaction_id", "status", "sourceRef"],
          "properties": {
            "contract_id": { "type": "string", "minLength": 1 },
            "provider": { "type": "string", "minLength": 1 },
            "consumer": { "type": "string", "minLength": 1 },
            "interaction_id": { "type": "string", "minLength": 1 },
            "status": { "enum": ["passed", "failed", "unknown"] },
            "required": { "type": "boolean" },
            "failure_class": { "type": "string" },
            "sourceRef": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": true
        }
      }
    }
  ]
}
