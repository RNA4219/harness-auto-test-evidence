{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HATE governance review report",
  "type": "object",
  "required": ["schema_version", "record_type", "report_id", "overall_status", "readiness_effect", "governance_config", "findings", "summary", "governance_diagnostics", "sourceRefs"],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {"const": "governance-review-report"},
    "report_id": {"type": "string"},
    "overall_status": {"enum": ["pass", "hold"]},
    "readiness_effect": {"enum": ["none", "hold"]},
    "governance_config": {
      "type": "object",
      "required": ["policy_templates", "exception_requests", "delegations", "audit_events", "review_packet", "self_approval_detected", "service_account_approval_detected", "policy_diff_required"],
      "properties": {
        "policy_templates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["template_id", "author", "approver", "effective_date", "review_cadence", "rollback_owner"],
            "properties": {
              "template_id": {"type": "string"},
              "author": {"type": "string"},
              "approver": {"type": "string"},
              "effective_date": {"type": "string"},
              "review_cadence": {"type": "string"},
              "affected_repo_set": {"type": "string"},
              "rollback_owner": {"type": "string"},
              "policy_diff_ref": {"type": "string"},
              "rollback_plan_ref": {"type": "string"},
              "sourceRef": {"type": "string"}
            },
            "additionalProperties": true
          }
        },
        "exception_requests": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["request_id", "owner", "expiry", "rationale", "affected_risks", "compensating_evidence", "reviewer_decision"],
            "properties": {
              "request_id": {"type": "string"},
              "owner": {"type": "string"},
              "expiry": {"type": "string"},
              "scope": {"type": "string"},
              "rationale": {"type": "string"},
              "affected_risks": {"type": "array", "items": {"type": "string"}},
              "compensating_evidence": {"type": "array", "items": {"type": "string"}},
              "reviewer_decision": {"type": "string"},
              "sourceRef": {"type": "string"}
            },
            "additionalProperties": true
          }
        },
        "delegations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "delegation_id": {"type": "string"},
              "delegator": {"type": "string"},
              "delegate": {"type": "string"},
              "scope": {"type": "string"},
              "expiry": {"type": "string"},
              "sourceRef": {"type": "string"}
            },
            "additionalProperties": true
          }
        },
        "audit_events": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "event_id": {"type": "string"},
              "target_ref": {"type": "string"},
              "actor": {"type": "string"},
              "event_type": {"type": "string"},
              "sourceRef": {"type": "string"}
            },
            "additionalProperties": true
          }
        },
        "review_packet": {
          "type": "object",
          "properties": {
            "expired_exception_count": {"type": "integer", "minimum": 0},
            "unresolved_high_risk_debt_count": {"type": "integer", "minimum": 0},
            "sourceRef": {"type": "string"}
          },
          "additionalProperties": true
        },
        "self_approval_detected": {"type": "boolean"},
        "service_account_approval_detected": {"type": "boolean"},
        "policy_diff_required": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message", "sourceRef", "readiness_effect"],
        "properties": {
          "code": {"type": "string"},
          "severity": {"type": "string"},
          "message": {"type": "string"},
          "sourceRef": {"type": "string"},
          "readiness_effect": {"enum": ["hold"]}
        },
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "policy_template_count",
        "exception_request_count",
        "delegation_count",
        "audit_event_count",
        "expired_exception_count",
        "unresolved_high_risk_debt_count",
        "duplicate_policy_template_count",
        "duplicate_exception_request_count",
        "template_source_ref_gap_count",
        "template_diff_or_rollback_gap_count",
        "exception_source_ref_gap_count",
        "exception_audit_gap_count",
        "broad_exception_count",
        "delegation_gap_count",
        "finding_count"
      ],
      "properties": {
        "policy_template_count": {"type": "integer", "minimum": 0},
        "exception_request_count": {"type": "integer", "minimum": 0},
        "delegation_count": {"type": "integer", "minimum": 0},
        "audit_event_count": {"type": "integer", "minimum": 0},
        "expired_exception_count": {"type": "integer", "minimum": 0},
        "unresolved_high_risk_debt_count": {"type": "integer", "minimum": 0},
        "duplicate_policy_template_count": {"type": "integer", "minimum": 0},
        "duplicate_exception_request_count": {"type": "integer", "minimum": 0},
        "template_source_ref_gap_count": {"type": "integer", "minimum": 0},
        "template_diff_or_rollback_gap_count": {"type": "integer", "minimum": 0},
        "exception_source_ref_gap_count": {"type": "integer", "minimum": 0},
        "exception_audit_gap_count": {"type": "integer", "minimum": 0},
        "broad_exception_count": {"type": "integer", "minimum": 0},
        "delegation_gap_count": {"type": "integer", "minimum": 0},
        "finding_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": true
    },
    "governance_diagnostics": {
      "type": "object",
      "required": [
        "duplicate_policy_templates",
        "duplicate_exception_requests",
        "templates_missing_source_ref",
        "templates_missing_diff_or_rollback",
        "templates_missing_separation",
        "exceptions_missing_source_ref",
        "exceptions_missing_risk_or_evidence",
        "exceptions_missing_audit_event",
        "broad_exception_requests",
        "delegations_without_bounds",
        "delegation_conflicts",
        "review_packet_missing_source_ref"
      ],
      "properties": {
        "duplicate_policy_templates": {"type": "array", "items": {"type": "string"}},
        "duplicate_exception_requests": {"type": "array", "items": {"type": "string"}},
        "templates_missing_source_ref": {"type": "array", "items": {"type": "string"}},
        "templates_missing_diff_or_rollback": {"type": "array", "items": {"type": "string"}},
        "templates_missing_separation": {"type": "array", "items": {"type": "string"}},
        "exceptions_missing_source_ref": {"type": "array", "items": {"type": "string"}},
        "exceptions_missing_risk_or_evidence": {"type": "array", "items": {"type": "string"}},
        "exceptions_missing_audit_event": {"type": "array", "items": {"type": "string"}},
        "broad_exception_requests": {"type": "array", "items": {"type": "string"}},
        "delegations_without_bounds": {"type": "array", "items": {"type": "string"}},
        "delegation_conflicts": {"type": "array", "items": {"type": "string"}},
        "review_packet_missing_source_ref": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "sourceRefs": {"type": "array", "items": {"type": "string"}}
  }
}
