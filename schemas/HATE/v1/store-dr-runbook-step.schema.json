{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/store-dr-runbook-step.schema.json",
  "title": "HATE Store DR Runbook Step",
  "type": "object",
  "required": [
    "record_type",
    "record_id",
    "created_at",
    "decision_basis",
    "readiness_effect",
    "unsafe_output_policy",
    "step_id",
    "status",
    "description",
    "required",
    "sourceRefs"
  ],
  "properties": {
    "record_type": {"const": "store-dr-runbook-step"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "step_id": {
      "type": "string",
      "enum": [
        "verify_backup_inventory",
        "verify_backup_hash",
        "verify_corruption_scan",
        "restore_store",
        "verify_legal_hold",
        "verify_rpo",
        "verify_rto",
        "rebuild_projection"
      ]
    },
    "status": {"type": "string", "enum": ["ready", "blocked"]},
    "description": {"type": "string"},
    "required": {"type": "boolean"},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [
    {"required": ["actor"]},
    {"required": ["system_actor"]}
  ],
  "additionalProperties": true
}
