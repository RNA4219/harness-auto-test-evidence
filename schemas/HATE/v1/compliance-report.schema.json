{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/compliance-report.schema.json",
  "title": "HATE Compliance Report",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "report_id",
    "overall_status",
    "readiness_effect",
    "compliance_evidence_pack",
    "procurement_questionnaire_export",
    "control_claims",
    "review_decisions",
    "findings",
    "summary",
    "sourceRefs",
    "record_id",
    "created_at",
    "decision_basis",
    "unsafe_output_policy"
  ],
  "properties": {
    "schema_version": {
      "const": "HATE/v1"
    },
    "record_type": {
      "const": "compliance-report"
    },
    "report_id": {
      "type": "string"
    },
    "overall_status": {
      "type": "string",
      "enum": [
        "pass",
        "hold"
      ]
    },
    "readiness_effect": {
      "type": "string",
      "enum": [
        "none",
        "hold"
      ]
    },
    "compliance_evidence_pack": {
      "type": "object",
      "additionalProperties": true
    },
    "procurement_questionnaire_export": {
      "type": "object",
      "additionalProperties": true
    },
    "control_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "record_type",
          "control_id",
          "claim_class",
          "claim_text",
          "evidence_refs",
          "expires_at"
        ],
        "properties": {
          "record_type": {
            "const": "control-claim-record"
          },
          "control_id": {
            "type": "string"
          },
          "claim_class": {
            "type": "string"
          },
          "claim_text": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expires_at": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "review_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "record_type",
          "control_id",
          "reviewer",
          "review_status",
          "reviewed_at",
          "expires_at"
        ],
        "properties": {
          "record_type": {
            "const": "compliance-review-decision"
          },
          "control_id": {
            "type": "string"
          },
          "reviewer": {
            "type": "string"
          },
          "review_status": {
            "type": "string"
          },
          "reviewed_at": {
            "type": "string"
          },
          "expires_at": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "severity",
          "message",
          "sourceRef",
          "readiness_effect"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "sourceRef": {
            "type": "string"
          },
          "readiness_effect": {
            "type": "string",
            "enum": [
              "hold"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "system_actor": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_basis": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "unsafe_output_policy": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true,
  "anyOf": [
    {
      "required": [
        "actor"
      ]
    },
    {
      "required": [
        "system_actor"
      ]
    }
  ]
}
