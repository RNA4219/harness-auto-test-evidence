{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/aete-score.schema.json",
  "title": "HATE AETE Score",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "run_id",
    "run_attempt",
    "rubric_version",
    "profile_version",
    "profile",
    "calibration_status",
    "score_confidence",
    "subject",
    "dimensions",
    "dimension_signals",
    "weighted_score",
    "reason_refs",
    "source_refs",
    "release_gate_override",
    "publish_gate_override"
  ],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {"const": "aete_score"},
    "run_id": {"type": "string"},
    "run_attempt": {"type": "integer", "minimum": 1},
    "rubric_version": {"type": "string"},
    "profile_version": {"type": "string"},
    "profile": {"type": "string"},
    "calibration_status": {"type": "string"},
    "score_confidence": {"type": "string"},
    "subject": {"type": "object"},
    "dimensions": {"type": "object"},
    "dimension_signals": {"type": "array"},
    "weighted_score": {"type": "number", "minimum": 0},
    "reason_refs": {"type": "array"},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "release_gate_override": {"const": false},
    "publish_gate_override": {"const": false}
  },
  "additionalProperties": true
}
