{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/artifact-resolver-map.schema.json",
  "title": "HATE Artifact Resolver Map",
  "type": "object",
  "required": ["schema_version", "record_type", "run_id", "entries", "summary"],
  "properties": {
    "schema_version": {"const": "HATE/v1"},
    "record_type": {"const": "artifact_resolution"},
    "run_id": {"type": "string"},
    "entries": {"type": "array"},
    "summary": {
      "type": "object",
      "required": ["entry_count", "unsafe_count", "unresolved_count", "artifact_path_count", "source_ref_count"]
    }
  },
  "additionalProperties": true
}
