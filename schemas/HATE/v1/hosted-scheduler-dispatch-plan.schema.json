{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.local/schemas/HATE/v1/hosted-scheduler-dispatch-plan.schema.json",
  "title": "HATE Hosted Scheduler Dispatch Plan",
  "type": "object",
  "required": ["record_type", "record_id", "created_at", "decision_basis", "readiness_effect", "unsafe_output_policy", "plan_id", "queue_id", "max_concurrency", "dispatch_entries", "sourceRefs"],
  "properties": {
    "record_type": {"const": "hosted-scheduler-dispatch-plan"},
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "system_actor": {"type": "string", "minLength": 1},
    "decision_basis": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "readiness_effect": {"type": "string", "enum": ["none", "hold"]},
    "unsafe_output_policy": {"type": "string", "minLength": 1},
    "plan_id": {"type": "string"},
    "queue_id": {"type": "string"},
    "max_concurrency": {"type": "integer", "minimum": 1},
    "dispatch_entries": {"type": "array", "items": {"type": "object"}},
    "sourceRefs": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  },
  "anyOf": [{"required": ["actor"]}, {"required": ["system_actor"]}],
  "additionalProperties": true
}
