{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hate.example/schemas/HATE-bridge/v1/bridge-request.schema.json",
  "title": "HATE bridge request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "bridge_id",
    "original_command",
    "owner",
    "canonical_contract",
    "status",
    "input_refs",
    "expected_output_types",
    "sourceRefs"
  ],
  "properties": {
    "schema_version": {
      "const": "HATE-bridge/v1"
    },
    "record_type": {
      "const": "bridge_request"
    },
    "bridge_id": {
      "type": "string",
      "pattern": "^hate-bridge-[a-f0-9]{24}$"
    },
    "original_command": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "canonical_contract": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "const": "handoff_required"
    },
    "input_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "argument",
          "path",
          "sha256",
          "kind"
        ],
        "properties": {
          "argument": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "kind": {
            "enum": [
              "file",
              "directory"
            ]
          }
        }
      }
    },
    "expected_output_types": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sourceRefs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "format": "uri"
      }
    }
  }
}
